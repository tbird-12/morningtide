---
import Layout from '../layouts/Layout.astro';

const psypactStates = [
	'Alabama', 'Arizona', 'Arkansas', 'Colorado', 'Commonwealth of the Northern Mariana Islands',
	'Connecticut', 'Delaware', 'District of Columbia', 'Florida', 'Georgia',
	'Idaho', 'Illinois', 'Indiana', 'Kansas', 'Kentucky',
	'Maine', 'Maryland', 'Michigan', 'Minnesota', 'Mississippi',
	'Missouri', 'Montana', 'Nebraska', 'Nevada', 'New Hampshire',
	'New Jersey', 'New Mexico', 'North Carolina', 'North Dakota', 'Ohio',
	'Oklahoma', 'Pennsylvania', 'Rhode Island', 'South Carolina', 'South Dakota',
	'Tennessee', 'Texas', 'Utah', 'Vermont', 'Virginia',
	'Washington', 'West Virginia', 'Wisconsin', 'Wyoming',
];
---

<Layout
	title="Locations | Morning Tide Consulting and Collective"
	description="Morning Tide provides remote psychological and psychoeducational evaluations across 40+ PSYPACT states. See the full list of eligible states."
>
	<main class="page-main">
		<section class="hero-shell mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Locations</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">Remote evaluations across {psypactStates.length} PSYPACT jurisdictions.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				Dr. Cornett holds PSYPACT APIT authorization, allowing remote evaluation services in participating states and territories with the same clinical standard across locations.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-[1.1fr_0.9fr]">
			<div class="section-shell rounded-4xl p-8">
				<p class="eyebrow">Eligible States &amp; Territories</p>
				<div class="mt-6 grid grid-cols-2 gap-x-6 gap-y-2 text-sm leading-7 text-(--color-muted) sm:grid-cols-3">
					{psypactStates.map((state) => (
						<span>{state}</span>
					))}
				</div>
				<p class="mt-6 text-xs leading-5 text-(--color-muted)">PSYPACT membership is updated periodically. If your state is not listed, contact us — new states join regularly.</p>
			</div>

			<div class="space-y-6">
				<div class="premium-card rounded-4xl p-8">
					<p class="eyebrow">How Remote Evaluations Work</p>
					<ul class="mt-4 space-y-3 text-sm leading-7 text-(--color-muted)">
						<li class="flex gap-3"><span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span><span>All sessions conducted via secure HIPAA-compliant video</span></li>
						<li class="flex gap-3"><span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span><span>Standardized testing administered through validated telehealth platforms</span></li>
						<li class="flex gap-3"><span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span><span>Intake, testing, report, and feedback — all completed remotely</span></li>
						<li class="flex gap-3"><span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span><span>Reports delivered within one week of testing</span></li>
					</ul>
				</div>

				<div class="premium-card rounded-4xl p-8">
					<p class="eyebrow">Licensure</p>
					<p class="mt-4 text-sm leading-7 text-(--color-muted)">Dr. Cornett is licensed in Kentucky and New Mexico, and holds a PSYPACT APIT credential. This allows her to practice telepsychology in all PSYPACT-participating jurisdictions without obtaining individual state licenses.</p>
				</div>
			</div>
		</section>

		<section class="cta-strip mx-auto mt-10 max-w-6xl">
			<div class="grid gap-8 lg:grid-cols-3">
				<div>
					<p class="eyebrow">No Waitlist</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Remote scheduling means no geographic bottleneck. Most clients are seen within one to two weeks of inquiry.</p>
				</div>
				<div>
					<p class="eyebrow">Same Standard Everywhere</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Every client receives the same comprehensive evaluation, detailed report, and individual feedback session — regardless of location.</p>
				</div>
				<div>
					<p class="eyebrow">Get Started</p>
					<a class="mt-4 inline-flex rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-(--color-button-ink) shadow-(--shadow-brand)" href="/#contact">Start with an inquiry</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
