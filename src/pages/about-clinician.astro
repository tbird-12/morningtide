---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="About Clinician | Morning Tide Consulting and Collective"
	description="Learn about the clinician behind MCC, including evaluation philosophy, scope, and approach to premium care."
>
	<main class="px-6 py-16 lg:px-10 lg:py-20">
		<section class="mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">About Clinician</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">A clinician-led practice built on careful work and clear communication.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				Use this page to introduce your credentials, licensure, and professional background.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-[1fr_1fr]">
			<div class="section-shell rounded-4xl p-8">
				<p class="eyebrow">Clinical Orientation</p>
				<p class="mt-4 text-base leading-8 text-(--color-muted)">
					Add your treatment and assessment orientation here, including populations served, typical referral questions, and your approach to balancing efficiency with depth.
				</p>
			</div>
			<div class="rounded-4xl border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
				<p class="eyebrow">Professional Profile</p>
				<ul class="mt-4 space-y-3 text-sm leading-7 text-(--color-muted)">
					<li>Credentials and training</li>
					<li>PSYPACT authorization and multi-state reach</li>
					<li>Primary service specialties</li>
					<li>Report style and delivery standards</li>
				</ul>
			</div>
		</section>
	</main>
</Layout>
