---
import Layout from '../layouts/Layout.astro';

const swatches = [
	{ label: 'Page', variable: '--color-page' },
	{ label: 'Surface', variable: '--color-surface' },
	{ label: 'Brand', variable: '--color-brand' },
	{ label: 'Accent', variable: '--color-accent' },
	{ label: 'Ink', variable: '--color-ink' },
];
---

<Layout
	title="Morning Tide Template"
	description="Starter website template built with Astro and Tailwind CSS using editable global color and font variables."
>
	<main class="min-h-screen">
		<section class="relative overflow-hidden">
			<div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,var(--color-brand-soft),transparent_35%),radial-gradient(circle_at_top_right,var(--color-accent-soft),transparent_30%)]"></div>
			<div class="mx-auto flex min-h-screen max-w-6xl flex-col px-6 py-8 lg:px-10">

				<div class="grid flex-1 items-center gap-16 py-10 lg:grid-cols-[1.1fr_0.9fr] lg:py-16">
					<div class="max-w-2xl space-y-8">
						<p class="text-sm font-semibold uppercase tracking-[0.32em] text-(--color-brand)">
							Editable design tokens
						</p>
						<h1 class="max-w-xl text-5xl leading-none text-(--color-ink) sm:text-6xl lg:text-7xl">
							Build the site, then swap the colors and fonts later.
						</h1>
						<p class="max-w-xl text-lg leading-8 text-(--color-muted) sm:text-xl">
							This starter keeps the structure intentionally lean. Tailwind handles layout and utilities, while global CSS variables define the palette and typography in one place.
						</p>
						<div class="flex flex-wrap gap-4">
							<a class="rounded-full bg-(--color-brand) px-6 py-3 text-sm font-semibold text-white shadow-[0_16px_40px_rgba(31,111,120,0.28)] transition hover:-translate-y-0.5" href="#theme">
								View theme tokens
							</a>
							<a class="rounded-full border border-(--color-line) bg-(--color-surface) px-6 py-3 text-sm font-semibold text-(--color-ink) transition hover:-translate-y-0.5" href="https://docs.astro.build">
								Astro docs
							</a>
						</div>
					</div>

					<div class="relative">
						<div class="absolute -inset-6 -z-10 rounded-4xl bg-[linear-gradient(135deg,var(--color-brand-soft),transparent_55%,var(--color-accent-soft))] blur-2xl opacity-80"></div>
						<div class="rounded-4xl border border-(--color-line) bg-[rgba(255,250,243,0.82)] p-6 shadow-[0_30px_80px_rgba(31,41,51,0.14)] backdrop-blur">
							<div class="flex items-center justify-between border-b border-(--color-line) pb-4">
								<p class="text-sm font-semibold uppercase tracking-[0.24em] text-(--color-muted)">
									Theme preview
								</p>
								<div class="flex gap-2">
									<span class="h-3 w-3 rounded-full bg-(--color-brand)"></span>
									<span class="h-3 w-3 rounded-full bg-(--color-accent)"></span>
									<span class="h-3 w-3 rounded-full bg-(--color-surface-strong)"></span>
								</div>
							</div>
							<div class="space-y-5 pt-6">
								<div class="rounded-3xl bg-(--color-brand) px-5 py-4 text-white">
									<p class="text-xs uppercase tracking-[0.24em] text-white/70">Primary accent</p>
									<p class="mt-3 text-2xl font-semibold">Use CSS variables first.</p>
								</div>
								<div class="grid gap-4 sm:grid-cols-2">
									<div class="rounded-[1.25rem] border border-(--color-line) bg-(--color-surface) p-4">
										<p class="text-xs uppercase tracking-[0.2em] text-(--color-muted)">Body font</p>
										<p class="mt-2 text-lg text-(--color-ink)">var(--font-body)</p>
									</div>
									<div class="rounded-[1.25rem] border border-(--color-line) bg-(--color-surface) p-4">
										<p class="text-xs uppercase tracking-[0.2em] text-(--color-muted)">Display font</p>
										<p class="mt-2 text-lg text-(--color-ink)" style="font-family: var(--font-display);">var(--font-display)</p>
									</div>
								</div>
								<div class="rounded-[1.25rem] border border-dashed border-(--color-line) p-4 text-sm leading-7 text-(--color-muted)">
									All color chips and section tones on this page are driven by the variables in <code>src/styles/global.css</code>.
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="theme" class="border-t border-(--color-line) bg-[rgba(255,250,243,0.72)] px-6 py-20 lg:px-10">
			<div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.95fr_1.05fr]">
				<div class="space-y-5">
					<p class="text-sm font-semibold uppercase tracking-[0.3em] text-(--color-brand)">Global theme layer</p>
					<h2 class="text-4xl leading-tight text-(--color-ink)">Change a few variables and the whole site shifts with them.</h2>
					<p class="max-w-xl text-lg leading-8 text-(--color-muted)">
						Keep brand decisions centralized in the global stylesheet. Tailwind utilities can then reference those values directly with CSS variables.
					</p>
				</div>

				<div class="grid gap-4 sm:grid-cols-2">
					{swatches.map((swatch) => (
						<div class="rounded-3xl border border-(--color-line) bg-(--color-surface) p-5 shadow-[0_12px_30px_rgba(31,41,51,0.06)]">
							<div class="h-20 rounded-2xl border border-black/5" style={`background-color: var(${swatch.variable});`}></div>
							<p class="mt-4 text-sm font-semibold uppercase tracking-[0.22em] text-(--color-muted)">{swatch.label}</p>
							<p class="mt-2 text-lg text-(--color-ink)">{swatch.variable}</p>
						</div>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>
