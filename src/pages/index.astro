---
import Layout from '../layouts/Layout.astro';

const pillars = [
	{
		title: 'Psychological Evaluations',
		description: 'Comprehensive assessment for diagnostic clarification, emotional functioning, attention concerns, and complex presentations.',
		href: '/services/psychological-evaluations',
	},
	{
		title: 'Psychoeducational Evaluations',
		description: 'Thoughtful testing that clarifies learning profiles, academic strengths, and the recommendations needed for school and family decision-making.',
		href: '/services/psychoeducational-testing',
	},
];

const differentiators = [
	'Strategic assessment plans tailored to the referral question',
	'Polished written reports built for real-world use',
	'Recommendations designed for clinicians, families, and schools',
	'A refined client experience from intake through feedback',
];

const process = [
	{
		step: '01',
		title: 'Initial Consultation',
		text: 'We begin with the referral question, relevant history, and the decisions the evaluation needs to support.',
	},
	{
		step: '02',
		title: 'Comprehensive Assessment',
		text: 'Testing, interviews, record review, and case formulation are selected with intention rather than by template.',
	},
	{
		step: '03',
		title: 'Integrated Report',
		text: 'Findings are translated into a clear, professionally written report with nuanced interpretation and practical recommendations.',
	},
	{
		step: '04',
		title: 'Feedback and Next Steps',
		text: 'A feedback session ensures results are understandable, actionable, and aligned with the client’s next decisions.',
	},
];

const signals = [
	{ label: 'Focus', value: 'High-touch evaluations' },
	{ label: 'Style', value: 'Depth over volume' },
	{ label: 'Deliverable', value: 'Clear, decision-ready reports' },
];
---

<Layout
	title="Morning Tide Psychology | Private Evaluations"
	description="Private psychological and psychoeducational evaluations for clients who value deep clinical thinking, precision, and polished recommendations."
>
	<main>
		<section class="relative overflow-hidden px-6 pt-10 pb-20 lg:px-10 lg:pt-16">
			<div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,var(--color-brand-soft),transparent_32%),radial-gradient(circle_at_85%_12%,var(--color-accent-soft),transparent_24%)]"></div>
			<div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
				<div class="space-y-8">
					<p class="eyebrow">Private Evaluation Practice</p>
					<h1 class="max-w-4xl text-wrap-balance text-5xl leading-none text-(--color-ink) sm:text-6xl lg:text-7xl">
						Psychological and psychoeducational evaluations for clients who value expertise, depth, and clarity.
					</h1>
					<p class="max-w-2xl text-lg leading-8 text-(--color-muted) sm:text-xl">
						Morning Tide Psychology is positioned for clients seeking comprehensive assessment, refined communication, and recommendations that stand up in clinical, academic, and family decision-making contexts.
					</p>
					<div class="flex flex-wrap gap-4">
						<a class="inline-flex items-center rounded-full bg-(--color-accent) px-6 py-3 text-sm font-semibold text-white shadow-(--shadow-brand) hover:-translate-y-0.5" href="/services">
							Explore Services
						</a>
						<a class="inline-flex items-center rounded-full border border-(--color-line) bg-(--color-surface) px-6 py-3 text-sm font-semibold text-(--color-ink) hover:-translate-y-0.5" href="#process">
							View the Process
						</a>
					</div>
					<div class="grid gap-4 sm:grid-cols-3">
						{signals.map((signal) => (
							<div class="premium-card rounded-[1.75rem] p-4">
								<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-(--color-brand)">{signal.label}</p>
								<p class="mt-3 text-base font-semibold text-(--color-ink)">{signal.value}</p>
							</div>
						))}
					</div>
				</div>

				<div class="section-shell rounded-[2rem] p-6 sm:p-8">
					<div class="flex items-start justify-between gap-4">
						<div>
							<p class="eyebrow">Why clients choose this practice</p>
							<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">A more elevated assessment experience.</h2>
						</div>
						<div class="rounded-full border border-(--color-line) px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-(--color-muted)">
							Premium Brand Positioning
						</div>
					</div>
					<div class="fine-rule my-6"></div>
					<div class="space-y-5">
						<p class="text-lg leading-8 text-(--color-muted)">
							This site is designed to speak to clients who want a thoughtful evaluator, a sophisticated process, and work product they can use with confidence.
						</p>
						<ul class="space-y-3 text-sm leading-7 text-(--color-muted)">
							{differentiators.map((item) => (
								<li class="flex gap-3">
									<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span>
									<span>{item}</span>
								</li>
							))}
						</ul>
						<div class="rounded-[1.5rem] border border-(--color-line-soft) bg-[color-mix(in_srgb,var(--color-accent)_8%,transparent)] p-5">
							<p class="text-[0.68rem] font-semibold uppercase tracking-[0.3em] text-(--color-brand)">Positioning Note</p>
							<p class="mt-3 text-base leading-7 text-(--color-ink)">
								The language across this site emphasizes discernment, professionalism, and outcomes rather than affordability, helping attract clients who value specialized expertise.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="px-6 py-20 lg:px-10">
			<div class="mx-auto max-w-6xl space-y-10">
				<div class="max-w-3xl space-y-4">
					<p class="eyebrow">Signature Services</p>
					<h2 class="text-4xl leading-none text-(--color-ink) sm:text-5xl">Focused offerings built around your strongest clinical work.</h2>
					<p class="text-lg leading-8 text-(--color-muted)">
						The site now centers your premium positioning around two core service lines: psychological evaluations and psychoeducational evaluations.
					</p>
				</div>
				<div class="grid gap-6 lg:grid-cols-2">
					{pillars.map((pillar) => (
						<a class="section-shell rounded-[2rem] p-8 hover:-translate-y-1" href={pillar.href}>
							<p class="eyebrow">Primary Service</p>
							<h3 class="mt-4 text-4xl leading-none text-(--color-ink)">{pillar.title}</h3>
							<p class="mt-5 max-w-xl text-base leading-8 text-(--color-muted)">{pillar.description}</p>
							<span class="mt-8 inline-flex items-center text-sm font-semibold text-(--color-accent)">
								Explore this service
							</span>
						</a>
					))}
				</div>
			</div>
		</section>

		<section id="process" class="bg-(--color-section-tint) px-6 py-20 lg:px-10">
			<div class="mx-auto max-w-6xl">
				<div class="max-w-3xl space-y-4">
					<p class="eyebrow">The Process</p>
					<h2 class="text-4xl leading-none text-(--color-ink) sm:text-5xl">A process that feels calm, deliberate, and professionally managed.</h2>
					<p class="text-lg leading-8 text-(--color-muted)">
						Premium clients respond to structure. This sequence communicates professionalism before they ever inquire.
					</p>
				</div>
				<div class="mt-12 grid gap-5 lg:grid-cols-4">
					{process.map((item) => (
						<div class="premium-card rounded-[1.75rem] p-6">
							<p class="text-sm font-semibold uppercase tracking-[0.22em] text-(--color-brand)">{item.step}</p>
							<h3 class="mt-4 text-3xl leading-none text-(--color-ink)">{item.title}</h3>
							<p class="mt-4 text-sm leading-7 text-(--color-muted)">{item.text}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section id="contact" class="px-6 py-20 lg:px-10">
			<div class="section-shell mx-auto max-w-6xl rounded-[2rem] px-8 py-10 sm:px-10 sm:py-12">
				<div class="grid gap-10 lg:grid-cols-[1fr_0.85fr] lg:items-center">
					<div class="space-y-5">
						<p class="eyebrow">Consultation Request</p>
						<h2 class="text-4xl leading-none text-(--color-ink) sm:text-5xl">Invite the right clients to take the next step.</h2>
						<p class="max-w-2xl text-lg leading-8 text-(--color-muted)">
							Use this section for your consultation form, scheduling link, or concierge intake workflow. The framing is intentionally high-trust and expertise-led.
						</p>
					</div>
					<div class="rounded-[1.75rem] border border-(--color-line-soft) bg-(--color-surface) p-6 shadow-(--shadow-soft)">
						<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-(--color-brand)">Suggested intake prompts</p>
						<ul class="mt-5 space-y-3 text-sm leading-7 text-(--color-muted)">
							<li>What questions are you hoping the evaluation will answer?</li>
							<li>Who will be using the report and recommendations?</li>
							<li>Are there academic, diagnostic, or treatment planning deadlines?</li>
						</ul>
						<a class="mt-6 inline-flex rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-white shadow-(--shadow-brand)" href="/services">
							Review services before inquiring
						</a>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
