---
import Layout from '../layouts/Layout.astro';
import FadeIn from '../components/FadeIn.tsx';
import AnimatedText from '../components/AnimatedText.tsx';
import AnimatedCard from '../components/AnimatedCard.tsx';

const services = [
	{
		title: 'Psychological Evaluations',
		description: 'ADHD, Autism, personality disorders, diagnostic clarification, and complex clinical presentations — built for high-masking and late-identified individuals.',
		href: '/services/psychological-evaluations',
	},
	{
		title: 'Psychoeducational Evaluations',
		description: 'Dyslexia, learning disorders, giftedness, twice-exceptional profiles, and academic achievement — with school-ready recommendations on a rapid timeline.',
		href: '/services/psychoeducational-testing',
	},
];

const process = [
	{
		step: '01',
		title: 'Clinical Intake',
		text: 'We review your referral question, developmental history, and relevant records to shape the evaluation.',
	},
	{
		step: '02',
		title: 'Comprehensive Testing',
		text: 'A tailored battery using gold-standard tools like ADOS-2, MIGDAS-2, CPTs, and cognitive measures.',
	},
	{
		step: '03',
		title: 'Integrated Report',
		text: 'Findings are synthesized into a detailed report with clinical interpretation and actionable recommendations.',
	},
	{
		step: '04',
		title: 'Feedback Session',
		text: 'A dedicated session to review results, answer questions, and align on clear next steps.',
	},
];

const differentiators = [
	{
		label: 'One Clinician, Start to Finish',
		text: 'Every evaluation is personally conducted by Dr. Heather Cornett — a licensed psychologist specializing in neurodivergent and complex diagnostic presentations.',
	},
	{
		label: 'Private-Pay by Design',
		text: 'Self-pay means evaluation scope is driven by clinical need, not insurer approval. Sensitive diagnostic information stays between you and your evaluator.',
	},
	{
		label: 'Reports in About One Week',
		text: 'Polished, in-depth reports are delivered days after testing — not the months-long waits common with insurance-based practices.',
	},
];

const clinicianOffers = [
	{
		title: 'Consultations',
		description: 'Hands-on guidance for billing, credentialing, paneling strategy, and the operational side of running a sustainable practice.',
		href: '/services/billing-and-credentialing-consultation',
	},
	{
		title: 'Continuing Education',
		description: 'Practice-grounded CEU trainings in ADHD assessment, autism evaluation, and testing methodology for agencies and clinicians.',
		href: '/services/ceu-trainings',
	},
];
---

<Layout
	title="Morning Tide Consulting and Collective | Expert Remote Psychological Evaluations"
	description="MCC offers expert self-pay psychological and psychoeducational evaluations across 40+ PSYPACT states — specializing in ADHD, Autism, learning disorders, and complex diagnostic cases. Reports within one week."
>
	<main class="page-main md:snap-y md:snap-proximity xl:snap-mandatory">

		<!-- ① HERO — Identity + promise + proof -->
		<section class="hero-shell relative flex min-h-[calc(100svh-var(--header-height-mobile))] snap-start items-center overflow-hidden md:min-h-[86vh]">
			<div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top_left,var(--color-brand-soft),transparent_32%),radial-gradient(circle_at_85%_12%,var(--color-accent-soft),transparent_24%)]"></div>
			<div class="mx-auto flex w-full max-w-4xl flex-col items-center text-center">
				<!-- IMAGE PLACEHOLDER: Hero/brand image — replace src with actual image path -->
				<FadeIn delay={0} duration={800} direction="none">
					<div class="mb-8 w-28 overflow-hidden rounded-3xl border border-(--color-line-soft) bg-(--color-section-tint) shadow-(--shadow-soft)">
						<div class="flex aspect-square items-center justify-center text-center text-xs text-(--color-muted)">
							<p>Logo or<br />brand image</p>
						</div>
					</div>
				</FadeIn>
				<FadeIn delay={100} duration={700}>
					<p class="eyebrow">Morning Tide Consulting and Collective</p>
				</FadeIn>
				<AnimatedText
					text="Expert evaluations for neurodivergent individuals, delivered remotely across 40+ states."
					as="h1"
					split="word"
					stagger={40}
					delay={250}
					duration={600}
					class="mt-8 text-wrap-balance text-5xl leading-none text-(--color-ink) sm:text-6xl lg:text-7xl"
				/>
				<FadeIn delay={600} duration={700}>
					<p class="mt-8 max-w-2xl text-lg leading-8 text-(--color-muted) sm:text-xl">
						Self-pay psychological and psychoeducational evaluations for ADHD, Autism, learning differences, and diagnostic clarity — with reports typically delivered within one week.
					</p>
				</FadeIn>
				<FadeIn delay={800} duration={600}>
					<div class="visual-grid mt-8 w-full max-w-3xl">
						<p class="visual-chip">40+ PSYPACT states</p>
						<p class="visual-chip">Report in about one week</p>
						<p class="visual-chip">Self-pay, privacy-forward</p>
					</div>
				</FadeIn>
				<FadeIn delay={950} duration={600}>
					<div class="mt-10 flex flex-wrap justify-center gap-4">
						<a class="inline-flex items-center rounded-full bg-(--color-accent) px-6 py-3 text-sm font-semibold text-(--color-button-ink) shadow-(--shadow-brand) transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg" href="#services">
							See What We Offer
						</a>
						<a class="inline-flex items-center rounded-full border border-(--color-line) bg-(--color-surface) px-6 py-3 text-sm font-semibold text-(--color-ink) transition-all duration-300 hover:-translate-y-0.5 hover:shadow" href="#process">
							How It Works
						</a>
					</div>
				</FadeIn>
			</div>
		</section>

		<!-- ② SERVICES — What we offer (core evaluation types) -->
		<section id="services" class="home-section snap-start">
			<div class="mx-auto w-full max-w-6xl space-y-10 px-4 sm:px-6 lg:px-10">
				<FadeIn>
					<div class="max-w-3xl space-y-4">
						<p class="eyebrow">What We Offer</p>
						<h2 class="text-4xl leading-none text-(--color-ink) sm:text-5xl">Two evaluation tracks, one standard of depth.</h2>
						<p class="text-lg leading-8 text-(--color-muted)">
							Every assessment is personally conducted by Dr. Heather Cornett, with a focus on nuanced neurodivergent and complex diagnostic presentations.
						</p>
					</div>
				</FadeIn>
				<div class="grid gap-6 lg:grid-cols-2">
					{services.map((service, i) => (
						<AnimatedCard href={service.href} index={i} className="section-shell rounded-4xl p-8 hover:-translate-y-1">
							<h3 class="text-4xl leading-none text-(--color-ink)">{service.title}</h3>
							<p class="mt-5 max-w-xl text-base leading-8 text-(--color-muted)">{service.description}</p>
							<span class="mt-8 inline-flex items-center text-sm font-semibold text-(--color-accent)">
								Learn more
							</span>
						</AnimatedCard>
					))}
				</div>
				<FadeIn delay={300}>
					<div class="flex justify-center pt-2">
						<a class="text-sm font-semibold text-(--color-accent) underline underline-offset-4" href="/services">View all services and pricing</a>
					</div>
				</FadeIn>
			</div>
		</section>

		<!-- ③ PROCESS — How an evaluation works (natural next question) -->
		<section id="process" class="home-section snap-start bg-(--color-section-tint)">
			<div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-10">
				<FadeIn>
					<div class="max-w-3xl space-y-4">
						<p class="eyebrow">How It Works</p>
						<h2 class="text-4xl leading-none text-(--color-ink) sm:text-5xl">Four steps from intake to answers.</h2>
						<p class="text-lg leading-8 text-(--color-muted)">
							Every evaluation follows the same structured process so you know exactly what to expect.
						</p>
					</div>
				</FadeIn>
				<div class="mt-12 grid gap-5 lg:grid-cols-4">
					{process.map((item, i) => (
						<AnimatedCard index={i} stagger={150} className="rounded-[1.75rem] p-6">
							<p class="text-sm font-semibold uppercase tracking-[0.22em] text-(--color-brand)">{item.step}</p>
							<h3 class="mt-4 text-3xl leading-none text-(--color-ink)">{item.title}</h3>
							<p class="mt-4 text-sm leading-7 text-(--color-muted)">{item.text}</p>
						</AnimatedCard>
					))}
				</div>
			</div>
		</section>

		<!-- ④ WHY MCC — Differentiators: clinician, model, speed -->
		<section class="home-section snap-start">
			<div class="mx-auto w-full max-w-6xl space-y-10 px-4 sm:px-6 lg:px-10">
				<FadeIn>
					<div class="max-w-3xl space-y-4">
						<p class="eyebrow">Why Morning Tide</p>
						<h2 class="text-4xl leading-none text-(--color-ink) sm:text-5xl">A practice built around depth, not volume.</h2>
					</div>
				</FadeIn>
				<div class="grid gap-6 lg:grid-cols-3">
					{differentiators.map((d, i) => (
						<AnimatedCard index={i} stagger={140} className="rounded-[1.75rem] p-6">
							<p class="eyebrow">{d.label}</p>
							<p class="mt-4 text-base leading-8 text-(--color-muted)">{d.text}</p>
						</AnimatedCard>
					))}
				</div>
				<FadeIn delay={400}>
					<div class="flex justify-center pt-2">
						<a class="text-sm font-semibold text-(--color-accent) underline underline-offset-4" href="/about-clinician">Meet Dr. Cornett</a>
					</div>
				</FadeIn>
			</div>
		</section>

		<!-- ⑤ CLINICIANS — Secondary audience, after client journey completes -->
		<section class="home-section snap-start bg-(--color-section-tint)">
			<div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-10">
				<FadeIn>
					<div class="cta-strip">
					<div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-center">
						<div class="space-y-4">
							<p class="eyebrow">For Clinicians</p>
							<h2 class="text-4xl leading-none text-(--color-ink) sm:text-5xl">Consulting and continuing education for fellow clinicians.</h2>
							<p class="text-base leading-8 text-(--color-muted)">
								MCC also supports clinicians with practical guidance and training grounded in real-world practice operating a multi-state evaluation practice.
							</p>
						</div>
						<div class="grid gap-4 sm:grid-cols-2">
							{clinicianOffers.map((offer, i) => (
								<AnimatedCard href={offer.href} index={i} className="rounded-3xl p-6 hover:-translate-y-1">
									<h3 class="text-lg font-semibold text-(--color-ink)">{offer.title}</h3>
									<p class="mt-3 text-sm leading-7 text-(--color-muted)">{offer.description}</p>
									<span class="mt-4 inline-flex text-sm font-semibold text-(--color-accent)">Learn more</span>
								</AnimatedCard>
							))}
						</div>
					</div>
				</FadeIn>
			</div>
		</section>

		<!-- ⑥ CONTACT — Warm, action-oriented CTA -->
		<section id="contact" class="home-section snap-start">
			<div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-10">
				<FadeIn class="section-shell rounded-4xl">
				<div class="mx-auto max-w-3xl space-y-6 text-center">
					<p class="eyebrow">Get Started</p>
					<AnimatedText
						text="Ready to get clear answers?"
						as="h2"
						split="word"
						stagger={60}
						delay={100}
						class="text-4xl leading-none text-(--color-ink) sm:text-5xl"
					/>
					<FadeIn delay={300}>
						<p class="text-lg leading-8 text-(--color-muted)">
							Share the questions you want the evaluation to answer, who will use the report, and any deadlines. We will follow up to confirm fit and schedule your intake.
						</p>
						<div class="flex flex-wrap justify-center gap-4 pt-4">
							<a class="inline-flex items-center rounded-full bg-(--color-accent) px-6 py-3 text-sm font-semibold text-(--color-button-ink) shadow-(--shadow-brand) transition-all duration-300 hover:-translate-y-0.5 hover:shadow-lg" href="mailto:info@morningtideconsulting.com">
								Start with an inquiry
							</a>
							<a class="inline-flex items-center rounded-full border border-(--color-line) bg-(--color-surface) px-6 py-3 text-sm font-semibold text-(--color-ink) transition-all duration-300 hover:-translate-y-0.5 hover:shadow" href="/services/investment">
								View pricing
							</a>
						</div>
						<p class="pt-2 text-xs text-(--color-muted)">MCC is a self-pay practice and is out-of-network with health insurance. HSA/FSA accepted.</p>
					</FadeIn>
				</div>
				</FadeIn>
			</div>
		</section>
	</main>
</Layout>

<style>
	.home-section {
		display: flex;
		align-items: center;
		padding-block: clamp(3.5rem, 8vw, 5.5rem);
	}

	@media (min-width: 768px) {
		.home-section {
			min-height: 85svh;
		}
	}

	@media (min-width: 1280px) {
		.home-section {
			min-height: 100svh;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		main {
			scroll-snap-type: none;
		}
	}
</style>
