---
import Layout from '../../layouts/Layout.astro';

const topics = [
	'Insurance billing workflows, documentation habits, and common denial patterns',
	'Credentialing and paneling strategy — which panels to join and when to stay off-panel',
	'Practice systems refinement: intake, scheduling, consent, and communication workflows',
	'Transitioning from insurance-based to private-pay or hybrid practice models',
	'Operationalizing testing services — from referral pipeline to report delivery',
	'Navigating PSYPACT, telehealth compliance, and multi-state practice logistics',
];

const facts = [
	{ label: 'Format', value: 'Virtual consultation via secure video' },
	{ label: 'Audience', value: 'Psychologists, LPAs, LPCAs, therapists' },
	{ label: 'Focus', value: 'Billing, credentialing, and practice operations' },
	{ label: 'Booking', value: 'By inquiry — tailored to your stage' },
];
---

<Layout
	title="Clinician Consultations | Morning Tide Consulting and Collective"
	description="Clinician consultation for mental health billing, insurance workflows, credentialing, practice operations, and PSYPACT logistics. Led by Dr. Heather Cornett."
>
	<main class="px-6 py-16 lg:px-10 lg:py-20">
		<section class="mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Clinician Consultations</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">Operational consulting for clinicians who want experienced, direct guidance.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				Dr. Cornett runs both a private-pay evaluation practice and an insurance-based group practice. This consultation draws on real experience managing billing systems, credentialing timelines, testing operations, and multi-state telehealth logistics — not theory.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-[1fr_0.95fr]">
			<div class="section-shell rounded-[2rem] p-8">
				<p class="eyebrow">What This Covers</p>
				<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">Practical depth from someone who runs it daily.</h2>
				<ul class="mt-6 space-y-3 text-sm leading-7 text-(--color-muted)">
					{topics.map((item) => (
						<li class="flex gap-3">
							<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>

			<div class="rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
				<p class="eyebrow">Consultation Details</p>
				<div class="mt-6 grid gap-4 sm:grid-cols-2">
					{facts.map((fact) => (
						<div class="premium-card rounded-[1.5rem] p-5">
							<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-(--color-brand)">{fact.label}</p>
							<p class="mt-3 text-base font-semibold text-(--color-ink)">{fact.value}</p>
						</div>
					))}
				</div>
				<div class="mt-6 rounded-2xl border border-(--color-line-soft) bg-(--color-section-tint) p-5">
					<p class="text-sm font-semibold text-(--color-ink)">Tailored to You</p>
					<p class="mt-2 text-sm leading-6 text-(--color-muted)">Consultations are structured around your specific bottleneck — whether that is credentialing strategy, billing efficiency, transitioning to private-pay, or building a testing arm. No cookie-cutter advice.</p>
				</div>
			</div>
		</section>

		<section class="mx-auto mt-10 max-w-6xl rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
			<div class="grid gap-8 lg:grid-cols-3">
				<div>
					<p class="eyebrow">Who This Is For</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Clinicians at any stage — from early-career providers learning billing to experienced practitioners optimizing their practice operations or expanding into testing.</p>
				</div>
				<div>
					<p class="eyebrow">What Clinicians Get</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Actionable guidance that you can implement immediately. No vague coaching — just direct answers from someone who has navigated the same systems.</p>
				</div>
				<div>
					<p class="eyebrow">Next Step</p>
					<a class="mt-4 inline-flex rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-white shadow-(--shadow-brand)" href="/#contact">Request a clinician consultation</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
