---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="Billing and Credentialing Consultation | Morning Tide"
	description="Stub page for billing and credentialing consultation for mental health providers."
>
	<main class="min-h-screen px-6 py-16 lg:px-10">
		<section class="mx-auto max-w-3xl space-y-6">
			<p class="text-sm font-semibold uppercase tracking-[0.28em] text-(--color-brand)">Consultation</p>
			<h1 class="text-4xl leading-tight text-(--color-ink) sm:text-5xl">Billing and Credentialing Consultation</h1>
			<p class="text-lg leading-8 text-(--color-muted)">
				Use this page to describe consultation support for insurance billing, paneling workflows, credentialing timelines, and systems setup.
			</p>
		</section>

		<section id="book-a-call" class="mx-auto mt-12 max-w-3xl rounded-3xl border border-(--color-line) bg-(--color-surface) p-6">
			<h2 class="text-2xl text-(--color-ink)">Book a Call</h2>
			<p class="mt-3 text-(--color-muted)">
				Add your booking method, availability window, and who this consultation is best suited for.
			</p>
		</section>

		<section id="faq" class="mx-auto mt-6 max-w-3xl rounded-3xl border border-(--color-line) bg-(--color-surface) p-6">
			<h2 class="text-2xl text-(--color-ink)">Frequently Asked Questions</h2>
			<p class="mt-3 text-(--color-muted)">
				Add your most common provider questions here, including pricing, time commitment, and expected outcomes.
			</p>
		</section>
	</main>
</Layout>
