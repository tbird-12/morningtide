---
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="Psychological Testing | Morning Tide Consulting and Collective"
	description="Stub page for psychological testing services."
>
	<main class="min-h-screen px-6 py-16 lg:px-10">
		<section class="mx-auto max-w-3xl space-y-6">
			<p class="text-sm font-semibold uppercase tracking-[0.28em] text-(--color-brand)">Services</p>
			<h1 class="text-4xl leading-tight text-(--color-ink) sm:text-5xl">Psychological Testing</h1>
			<p class="text-lg leading-8 text-(--color-muted)">
				Replace this section with your full psychological testing service description, testing process, timelines, and referral details.
			</p>
			<a class="inline-flex rounded-full border border-(--color-line) bg-(--color-surface) px-5 py-2 text-sm font-semibold text-(--color-ink)" href="/services">
				Back to all services
			</a>
		</section>
	</main>
</Layout>
