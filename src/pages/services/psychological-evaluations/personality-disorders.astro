---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
	title="Personality Disorder Evaluations | Morning Tide"
	description="Stub page for personality disorder evaluation services."
>
	<main class="min-h-screen px-6 py-16 lg:px-10">
		<section class="mx-auto max-w-3xl space-y-6">
			<p class="text-sm font-semibold uppercase tracking-[0.28em] text-(--color-brand)">Psychological Evaluations</p>
			<h1 class="text-4xl leading-tight text-(--color-ink) sm:text-5xl">Personality Disorder Evaluations</h1>
			<p class="text-lg leading-8 text-(--color-muted)">
				Replace this section with your approach to personality disorder evaluation, the instruments used, and what clients can expect from the assessment and feedback process.
			</p>
			<a class="inline-flex rounded-full border border-(--color-line) bg-(--color-surface) px-5 py-2 text-sm font-semibold text-(--color-ink)" href="/services/psychological-evaluations">
				Back to psychological evaluations
			</a>
		</section>
	</main>
</Layout>
