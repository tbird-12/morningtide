---
import Layout from '../../../layouts/Layout.astro';

const referralQuestions = [
	'Need for deeper personality assessment beyond brief screening — exploring long-term patterns of relating to the self and others',
	'Questions about borderline personality, narcissistic features, or other complex personality presentations',
	'Longstanding interpersonal, emotional, or self-concept patterns that have not responded to standard treatment',
	'Need for a professionally written report that supports treatment planning and therapeutic breakthroughs',
];

const facts = [
	{ label: 'Format', value: 'Remote evaluation' },
	{ label: 'Approach', value: 'Personality inventories & clinical interview' },
	{ label: 'Turnaround', value: 'Report within one week' },
	{ label: 'Rate', value: '$1,500 private-pay' },
];
---

<Layout
	title="Personality Disorder Evaluations | Morning Tide Consulting and Collective"
	description="Remote personality-focused evaluations with clinical depth and discretion. Assessment of complex personality presentations, BPD, and co-occurring conditions. Reports within one week across 40+ PSYPACT states."
>
	<main class="page-main">
		<section class="hero-shell mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Psychological Evaluations</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">Personality-focused evaluations with discretion and depth.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				Personality evaluations explore long-term patterns of relating to the self and others — providing the clinical foundation for therapeutic breakthroughs and treatment planning. Dr. Cornett's graduate training centered on complex personality presentations, including borderline personality disorder, giving her particular depth with these sensitive evaluations. The self-pay model ensures complete privacy and discretion.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-[1fr_0.95fr]">
			<div class="section-shell rounded-[2rem] p-8">
				<p class="eyebrow">Common Referral Questions</p>
				<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">A private evaluation process for sensitive clinical questions.</h2>
				<ul class="mt-6 space-y-3 text-sm leading-7 text-(--color-muted)">
					{referralQuestions.map((item) => (
						<li class="flex gap-3">
							<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>

			<div class="rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
				<p class="eyebrow">At a Glance</p>
				<div class="mt-6 grid gap-4 sm:grid-cols-2">
					{facts.map((fact) => (
						<div class="premium-card rounded-[1.5rem] p-5">
							<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-(--color-brand)">{fact.label}</p>
							<p class="mt-3 text-base font-semibold text-(--color-ink)">{fact.value}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="mx-auto mt-10 max-w-6xl rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
			<div class="grid gap-8 lg:grid-cols-3">
				<div>
					<p class="eyebrow">Private-Pay Only</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">We are out-of-network with health insurance. Self-pay is especially important for personality evaluations — it ensures full privacy and keeps sensitive information out of insurance systems.</p>
				</div>
				<div>
					<p class="eyebrow">Discretion</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Because these evaluations often involve deeply personal material, the private-pay model supports greater confidentiality and clinical autonomy throughout the process.</p>
				</div>
				<div>
					<p class="eyebrow">Next Step</p>
					<a class="mt-4 inline-flex rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-(--color-button-ink) shadow-(--shadow-brand)" href="/#contact">Start with an inquiry</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
