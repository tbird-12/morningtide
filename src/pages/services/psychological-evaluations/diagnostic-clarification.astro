---
import Layout from '../../../layouts/Layout.astro';

const referralQuestions = [
	'Complex presentations where the current diagnosis does not fully explain the experience',
	'Overlapping symptoms across anxiety, depression, bipolar disorder, PTSD, and neurodevelopmental conditions',
	'Need to distinguish between conditions that share surface-level features but require different treatment approaches',
	'Need for a clear, actionable report that guides treatment planning and clinical decision-making',
];

const areas = [
	{
		title: 'Mood & Anxiety Disorders',
		description: 'Distinguishing between complex presentations of anxiety, depression, bipolar disorder, and PTSD.',
	},
	{
		title: 'Neurodevelopmental Overlap',
		description: 'Clarifying whether ADHD, autism, or both better explain a person\'s experience — especially in high-masking individuals.',
	},
	{
		title: 'Psychotic Features',
		description: 'Evaluating for schizophrenia spectrum conditions, brief psychotic episodes, and psychosis-like features in other disorders.',
	},
	{
		title: 'Treatment Planning',
		description: 'Providing the clinical documentation needed for specialized therapy, medication adjustments, or workplace and academic accommodations.',
	},
];

const facts = [
	{ label: 'Format', value: 'Remote evaluation' },
	{ label: 'Scope', value: 'Multi-condition differential analysis' },
	{ label: 'Turnaround', value: 'Report within one week' },
	{ label: 'Rate', value: '$1,500 private-pay' },
];
---

<Layout
	title="Diagnostic Clarification | Morning Tide Consulting and Collective"
	description="Remote diagnostic clarification evaluations for complex or unclear clinical pictures. Specializing in overlapping diagnoses, comorbidity, and treatment planning across 40+ PSYPACT states."
>
	<main class="page-main">
		<section class="hero-shell mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Psychological Evaluations</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">Diagnostic clarification for complex or unclear clinical pictures.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				When symptoms overlap and answers are unclear, a structured evaluation provides the evidence-based lens needed to move forward. Dr. Cornett spent her graduate training specializing in severe and persistent mental illness — including borderline personality disorder, bipolar disorder, and schizophrenia spectrum conditions — giving her the clinical depth to untangle complex presentations where prior diagnoses have not fully fit.
			</p>
		</section>

		<section class="mx-auto mt-12 max-w-6xl space-y-6">
			<div class="section-shell rounded-[2rem] p-8 lg:p-10">
				<p class="eyebrow">Areas of Clarification</p>
				<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">When the clinical picture needs sharper focus.</h2>
				<div class="mt-8 grid gap-4 sm:grid-cols-2">
					{areas.map((item) => (
						<div class="rounded-2xl border border-(--color-line-soft) bg-(--color-surface) p-5">
							<p class="text-sm font-semibold text-(--color-ink)">{item.title}</p>
							<p class="mt-2 text-sm leading-6 text-(--color-muted)">{item.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-[1fr_0.95fr]">
			<div class="section-shell rounded-[2rem] p-8">
				<p class="eyebrow">Common Referral Questions</p>
				<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">A clearer clinical picture, on a reasonable timeline.</h2>
				<ul class="mt-6 space-y-3 text-sm leading-7 text-(--color-muted)">
					{referralQuestions.map((item) => (
						<li class="flex gap-3">
							<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>

			<div class="rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
				<p class="eyebrow">At a Glance</p>
				<div class="mt-6 grid gap-4 sm:grid-cols-2">
					{facts.map((fact) => (
						<div class="premium-card rounded-[1.5rem] p-5">
							<p class="text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-(--color-brand)">{fact.label}</p>
							<p class="mt-3 text-base font-semibold text-(--color-ink)">{fact.value}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<section class="mx-auto mt-10 max-w-6xl rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
			<div class="grid gap-8 lg:grid-cols-3">
				<div>
					<p class="eyebrow">Private-Pay Only</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">We are out-of-network with health insurance. Self-pay ensures the assessment is driven by clinical need — not by what a payer will authorize.</p>
				</div>
				<div>
					<p class="eyebrow">Privacy</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Private-pay evaluations keep sensitive diagnostic information between you and your evaluator — critical for complex and personal clinical questions.</p>
				</div>
				<div>
					<p class="eyebrow">Next Step</p>
					<a class="mt-4 inline-flex rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-(--color-button-ink) shadow-(--shadow-brand)" href="/#contact">Start with an inquiry</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
