---
import Layout from '../../../layouts/Layout.astro';

const categories = [
	{ label: 'ADHD Evaluations', href: '/services/psychological-evaluations/adhd' },
	{ label: 'Autism Evaluations', href: '/services/psychological-evaluations/autism' },
	{ label: 'Diagnostic Clarification', href: '/services/psychological-evaluations/diagnostic-clarification' },
	{ label: 'Personality Assessment', href: '/services/psychological-evaluations/personality-disorders' },
];

const highlights = [
	'Remote evaluations available across 40+ PSYPACT states — no travel required',
	'Completed evaluation and polished report delivered on a rapid timeline',
	'Specializing in high-masking neurodivergent individuals and complex presentations',
	'Gold-standard assessment tools including ADOS-2, MIGDAS-2, and cognitive batteries',
	'Integrated interpretation and actionable recommendations — not just disconnected test scores',
	'Self-pay model ensures privacy, clinical autonomy, and expedited delivery',
];
---

<Layout
	title="Psychological Evaluations | Morning Tide Consulting and Collective"
	description="Premium self-pay remote psychological evaluations for ADHD, Autism, personality disorders, diagnostic clarification, and complex clinical questions. Specializing in high-masking neurodivergent individuals across 40+ PSYPACT states."
>
	<main class="page-main">
		<section class="hero-shell mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Psychological Evaluations</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">Premium remote evaluations for clients who need clear diagnostic answers.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				A psychological evaluation clarifies the "why" behind emotional, behavioral, or cognitive patterns so treatment and support decisions can be made with confidence.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="section-shell rounded-[2rem] p-8">
				<p class="eyebrow">What sets this apart</p>
				<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">Premium evaluations with unmatched availability.</h2>
				<ul class="mt-6 space-y-3 text-sm leading-7 text-(--color-muted)">
					{highlights.map((item) => (
						<li class="flex gap-3">
							<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>

			<div class="premium-card rounded-[2rem] p-8">
				<p class="eyebrow">Areas of Focus</p>
				<div class="mt-6 grid gap-4 sm:grid-cols-2">
			{categories.map((category) => (
				<a
					class="premium-card rounded-[1.5rem] px-5 py-5 text-base font-semibold text-(--color-ink)"
					href={category.href}
				>
					{category.label}
				</a>
			))}
				</div>
			</div>
		</section>

		<section class="cta-strip mx-auto mt-14 max-w-6xl">
			<div class="grid gap-8 lg:grid-cols-3">
				<div>
					<p class="eyebrow">Best Fit</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Individuals seeking thorough diagnostic clarity — especially those who have not found answers through prior screenings, brief evaluations, or standard clinical care.</p>
				</div>
				<div>
					<p class="eyebrow">What You Receive</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">A clear clinical picture, integrated diagnostic interpretation, and a detailed written report with actionable recommendations — delivered promptly after testing.</p>
				</div>
				<div>
					<p class="eyebrow">Next Step</p>
					<a class="mt-4 inline-flex rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-(--color-button-ink) shadow-(--shadow-brand)" href="/#contact">Start with an inquiry</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
