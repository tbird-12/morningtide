---
import Layout from '../../../layouts/Layout.astro';

const categories = [
	{ label: 'ADHD Evaluations', href: '/services/psychological-evaluations/adhd' },
	{ label: 'Autism Evaluations', href: '/services/psychological-evaluations/autism' },
	{ label: 'Diagnostic Clarification', href: '/services/psychological-evaluations/diagnostic-clarification' },
	{ label: 'Learning Disorders', href: '/services/psychological-evaluations/learning-disorders' },
	{ label: 'Personality Assessment', href: '/services/psychological-evaluations/personality-disorders' },
];

const highlights = [
	'Remote evaluations available across 43+ PSYPACT states',
	'Completed evaluation and polished report typically within one week',
	'Assessment planning matched to the actual referral question',
	'Integrated interpretation rather than disconnected test scores',
	'Clear written reports designed for treatment and decision-making',
];
---

<Layout
	title="Psychological Evaluations | Morning Tide Consulting and Collective"
	description="Remote psychological evaluations across 43+ PSYPACT states for diagnostic clarification, attention concerns, autism, personality assessment, and complex clinical questions."
>
	<main class="px-6 py-16 lg:px-10 lg:py-20">
		<section class="mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Psychological Evaluations</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">Comprehensive remote assessment for clients who need nuanced diagnostic clarity fast.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				This service line is ideal for referral questions that require careful formulation, broad differential thinking, and a report that can support treatment planning, personal understanding, and professional collaboration, all through a streamlined remote process available across 43+ PSYPACT states.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-[0.9fr_1.1fr]">
			<div class="section-shell rounded-[2rem] p-8">
				<p class="eyebrow">What this communicates</p>
				<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">A selective, high-touch evaluation offering with unusually strong availability.</h2>
				<ul class="mt-6 space-y-3 text-sm leading-7 text-(--color-muted)">
					{highlights.map((item) => (
						<li class="flex gap-3">
							<span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-(--color-brand)"></span>
							<span>{item}</span>
						</li>
					))}
				</ul>
			</div>

			<div class="rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
				<p class="eyebrow">Areas of Focus</p>
				<div class="mt-6 grid gap-4 sm:grid-cols-2">
			{categories.map((category) => (
				<a
					class="premium-card rounded-[1.5rem] px-5 py-5 text-base font-semibold text-(--color-ink)"
					href={category.href}
				>
					{category.label}
				</a>
			))}
				</div>
			</div>
		</section>

		<section class="mx-auto mt-14 max-w-6xl rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
			<div class="grid gap-8 lg:grid-cols-3">
				<div>
					<p class="eyebrow">Best Fit</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Clients seeking a careful, polished evaluation experience with remote convenience and quick access across PSYPACT states.</p>
				</div>
				<div>
					<p class="eyebrow">Typical Outcome</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">A clear understanding of the clinical picture plus a polished report, typically completed within one week.</p>
				</div>
				<div>
					<p class="eyebrow">Next Step</p>
					<a class="mt-4 inline-flex rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-white shadow-(--shadow-brand)" href="/#contact">Request a consultation</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
