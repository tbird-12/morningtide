---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
	title="Autism Testing Training | Morning Tide"
	description="CEU training on autism assessment and evaluation for mental health providers."
>
	<main class="min-h-screen px-6 py-16 lg:px-10">
		<section class="mx-auto max-w-3xl space-y-6">
			<p class="text-sm font-semibold uppercase tracking-[0.28em] text-(--color-brand)">CEU Trainings</p>
			<h1 class="text-4xl leading-tight text-(--color-ink) sm:text-5xl">Autism Testing Training</h1>
			<p class="text-lg leading-8 text-(--color-muted)">
				Replace this section with your autism testing training content, learning objectives, CE credit hours, format, and registration details for mental health providers.
			</p>
			<a class="inline-flex rounded-full border border-(--color-line) bg-(--color-surface) px-5 py-2 text-sm font-semibold text-(--color-ink)" href="/services/ceu-trainings">
				Back to CEU Trainings
			</a>
		</section>
	</main>
</Layout>
