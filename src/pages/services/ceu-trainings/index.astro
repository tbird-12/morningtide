---
import Layout from '../../../layouts/Layout.astro';

const trainings = [
	{ label: 'ADHD Training', href: '/services/ceu-trainings/adhd-training' },
	{ label: 'Autism Testing Training', href: '/services/ceu-trainings/autism-testing-training' },
];
---

<Layout
	title="Education | Morning Tide Consulting and Collective"
	description="Continuing education trainings for mental health providers through Morning Tide Consulting and Collective."
>
	<main class="px-6 py-16 lg:px-10 lg:py-20">
		<section class="mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Education</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">Continuing education for clinicians who want relevant, practice-grounded training.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				Trainings for agencies, group practices, and individual clinicians — substantive, practical, and immediately useful in clinical work.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-[0.95fr_1.05fr]">
			<div class="section-shell rounded-[2rem] p-8">
				<p class="eyebrow">Our Approach</p>
				<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">Training that reflects the same standards as the rest of the practice.</h2>
				<p class="mt-5 text-base leading-8 text-(--color-muted)">
					Use this page to present learning objectives, training formats, and booking details.
				</p>
			</div>

			<div class="rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
				<p class="eyebrow">Current Training Topics</p>
				<div class="mt-6 grid gap-4 sm:grid-cols-2">
			{trainings.map((training) => (
				<a
					class="premium-card rounded-[1.5rem] px-5 py-5 text-base font-semibold text-(--color-ink)"
					href={training.href}
				>
					{training.label}
				</a>
			))}
				</div>
			</div>
		</section>

		<section class="mx-auto mt-10 max-w-6xl rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
			<div class="grid gap-8 lg:grid-cols-3">
				<div>
					<p class="eyebrow">Formats</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Use this section for live training, organization workshops, or tailored education events.</p>
				</div>
				<div>
					<p class="eyebrow">Audience</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Clinicians, agencies, and teams looking for practical continuing education with clinical depth.</p>
				</div>
				<div>
					<p class="eyebrow">Booking</p>
					<a class="mt-4 inline-flex rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-white shadow-(--shadow-brand)" href="/#contact">Request a training inquiry</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
