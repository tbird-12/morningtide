---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
	title="Academic Achievement Testing | Morning Tide"
	description="Stub page for academic achievement testing services."
>
	<main class="min-h-screen px-6 py-16 lg:px-10">
		<section class="mx-auto max-w-3xl space-y-6">
			<p class="text-sm font-semibold uppercase tracking-[0.28em] text-(--color-brand)">Psychoeducational Testing</p>
			<h1 class="text-4xl leading-tight text-(--color-ink) sm:text-5xl">Academic Achievement Testing</h1>
			<p class="text-lg leading-8 text-(--color-muted)">
				Replace this section with details on what academic achievement testing covers, the grade levels and domains assessed, and how results are shared with families and educators.
			</p>
			<a class="inline-flex rounded-full border border-(--color-line) bg-(--color-surface) px-5 py-2 text-sm font-semibold text-(--color-ink)" href="/services/psychoeducational-testing">
				Back to psychoeducational testing
			</a>
		</section>
	</main>
</Layout>
