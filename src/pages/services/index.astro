---
import Layout from '../../layouts/Layout.astro';

const primaryServices = [
	{
		label: 'Psychological Evaluations',
		href: '/services/psychological-evaluations',
		description: 'Diagnostic evaluations for ADHD, autism, personality disorders, learning disorders, guardianship, and diagnostic clarification. Built for nuanced cases — including high-masking presentations and co-occurring conditions rooted in severe and persistent mental illness (SPMI).',
	},
	{
		label: 'Psychoeducational Evaluations',
		href: '/services/psychoeducational-testing',
		description: 'Cognitive and academic testing for dyslexia, learning disorders, giftedness, twice-exceptional profiles, and academic achievement — producing school-ready documentation with rapid report delivery.',
	},
];

const secondaryServices = [
	{
		label: 'Consultations',
		href: '/services/billing-and-credentialing-consultation',
		description: 'Hands-on guidance for clinicians navigating insurance billing, credentialing, paneling strategy, and the operational side of running a sustainable practice.',
	},
	{
		label: 'Education',
		href: '/services/ceu-trainings',
		description: 'Practice-grounded continuing education in ADHD assessment, autism evaluation, and testing methodology — for agencies, group practices, and individual clinicians.',
	},
];
---

<Layout
	title="Services | Morning Tide Consulting and Collective"
	description="Premium self-pay psychological and psychoeducational evaluations, clinician consultations, and continuing education. Remote across 40+ PSYPACT states."
>
	<main class="px-6 py-16 lg:px-10 lg:py-20">
		<section class="mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Services</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">Premium evaluations, clinician consulting, and continuing education.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				MCC is a self-pay practice specializing in rigorous psychological and psychoeducational evaluations for neurodivergent individuals — available remotely across 40+ PSYPACT states. Clinician consulting and continuing education round out the offering.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-2">
			{primaryServices.map((service) => (
				<a
					class="section-shell rounded-4xl px-7 py-8 hover:-translate-y-1"
					href={service.href}
				>
					<p class="eyebrow">Primary Service</p>
					<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">{service.label}</h2>
					<p class="mt-5 text-base leading-8 text-(--color-muted)">{service.description}</p>
					<span class="mt-8 inline-flex text-sm font-semibold text-(--color-accent)">View service details</span>
				</a>
			))}
		</section>

		<section class="mx-auto mt-12 max-w-6xl rounded-4xl border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
			<div class="grid gap-8 lg:grid-cols-3">
				<div>
					<p class="eyebrow">Self-Pay Only</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Insurance is not accepted. Private-pay ensures faster turnaround, complete clinical autonomy, and greater privacy for every client.</p>
				</div>
				<div>
					<p class="eyebrow">Remote Access</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">All evaluations are conducted remotely via PSYPACT, reaching clients in 40+ participating states from the comfort of their home.</p>
				</div>
				<div>
					<p class="eyebrow">Fast Turnaround</p>
					<p class="mt-4 text-base leading-8 text-(--color-muted)">Polished, in-depth reports are completed on a rapid timeline — not the months-long wait common with insurance-based practices.</p>
				</div>
			</div>
		</section>

		<section class="mx-auto mt-16 max-w-6xl rounded-4xl border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
			<div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
				<div class="space-y-4">
					<p class="eyebrow">Clinician-Facing Services</p>
					<h2 class="text-4xl leading-none text-(--color-ink)">Consulting and continuing education for clinicians.</h2>
					<p class="text-base leading-8 text-(--color-muted)">
						Built from real-world experience running a multi-state psychological testing practice. These offerings support clinicians in building stronger practices and deepening their clinical skills.
					</p>
				</div>
				<div class="grid gap-4 sm:grid-cols-2">
					{secondaryServices.map((service) => (
						<a class="premium-card rounded-3xl px-5 py-5" href={service.href}>
							<p class="text-base font-semibold text-(--color-ink)">{service.label}</p>
							<p class="mt-3 text-sm leading-7 text-(--color-muted)">{service.description}</p>
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>
