---
import Layout from '../../layouts/Layout.astro';

const primaryServices = [
	{
		label: 'Psychological Evaluations',
		href: '/services/psychological-evaluations',
		description: 'Assessment for diagnostic clarification, attention concerns, emotional functioning, and complex clinical presentations.',
	},
	{
		label: 'Psychoeducational Evaluations',
		href: '/services/psychoeducational-testing',
		description: 'Testing focused on learning profiles, academic strengths, school planning, and clear educational recommendations.',
	},
];

const secondaryServices = [
	{ label: 'CEU Trainings', href: '/services/ceu-trainings' },
	{ label: 'Professional Consultation', href: '/services/billing-and-credentialing-consultation' },
];
---

<Layout
	title="Services | Morning Tide"
	description="Overview of Morning Tide Psychology services with premium positioning around psychological and psychoeducational evaluations."
>
	<main class="px-6 py-16 lg:px-10 lg:py-20">
		<section class="mx-auto max-w-6xl space-y-8">
			<p class="eyebrow">Services</p>
			<h1 class="max-w-4xl text-5xl leading-none text-(--color-ink) sm:text-6xl">A focused practice centered on premium evaluation work.</h1>
			<p class="max-w-3xl text-lg leading-8 text-(--color-muted)">
				This service architecture puts your strongest clinical offerings first and presents other professional services as secondary. The effect is more selective, more polished, and better aligned with an expertise-driven brand.
			</p>
		</section>

		<section class="mx-auto mt-12 grid max-w-6xl gap-6 lg:grid-cols-2">
			{primaryServices.map((service) => (
				<a
					class="section-shell rounded-[2rem] px-7 py-8 hover:-translate-y-1"
					href={service.href}
				>
					<p class="eyebrow">Primary Service</p>
					<h2 class="mt-4 text-4xl leading-none text-(--color-ink)">{service.label}</h2>
					<p class="mt-5 text-base leading-8 text-(--color-muted)">{service.description}</p>
					<span class="mt-8 inline-flex text-sm font-semibold text-(--color-accent)">View service details</span>
				</a>
			))}
		</section>

		<section class="mx-auto mt-16 max-w-6xl rounded-[2rem] border border-(--color-line-soft) bg-(--color-surface) p-8 shadow-(--shadow-soft)">
			<div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
				<div class="space-y-4">
					<p class="eyebrow">Additional Services</p>
					<h2 class="text-4xl leading-none text-(--color-ink)">Secondary offerings remain available without competing for attention.</h2>
					<p class="text-base leading-8 text-(--color-muted)">
						This keeps the homepage and service hierarchy focused on your evaluation expertise while preserving access to other professional work in the existing site structure.
					</p>
				</div>
				<div class="grid gap-4 sm:grid-cols-2">
					{secondaryServices.map((service) => (
						<a class="premium-card rounded-[1.5rem] px-5 py-5 text-base font-semibold text-(--color-ink)" href={service.href}>
							{service.label}
						</a>
					))}
				</div>
			</div>
		</section>
	</main>
</Layout>
