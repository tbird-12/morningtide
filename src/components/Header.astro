---
const navigation = [
	{
		label: 'About',
		href: '/about-clinician',
		children: [
			{ label: 'Clinician', href: '/about-clinician' },
			{ label: 'FAQ', href: '/faq' },
			{ label: 'Investment', href: '/services/investment' },
			{ label: 'Locations', href: '/locations' },	
		],
	},
	{
		label: 'Evaluations',
		href: '/services',
		children: [
			{ label: 'Psychological Evaluations', href: '/services/psychological-evaluations' },
			{ label: 'Psychoeducational Evaluations', href: '/services/psychoeducational-testing' },
		],
	},
	{ label: 'Consultations', href: '/services/billing-and-credentialing-consultation' },
	{ label: 'Education', href: '/services/ceu-trainings' },
	
];

// Mobile: show first 2 nav items, rest under "More"
const mobileVisibleNav = navigation.slice(0, 2);
const mobileMoreNav = navigation.slice(2);
---

<header class="fixed md:sticky top-0 left-0 right-0 z-40 border-b border-(--color-line-soft) bg-(--color-header-bg) backdrop-blur-xl">
	<div class="mx-auto hidden max-w-6xl items-center justify-between px-4 py-4 md:flex md:px-6 lg:px-10">
		<a class="group flex items-center gap-4" href="/" aria-label="Morning Tide Consulting and Collective home">
			<div class="flex h-11 w-11 items-center justify-center rounded-full border border-(--color-line) bg-surface text-lg font-semibold text-(--color-brand) shadow-(--shadow-soft)">
				MCC
			</div>
			<div>
				<p class="text-[0.68rem] font-semibold uppercase tracking-[0.32em] text-(--color-brand)">Morning Tide Consulting</p>
				<p class="text-lg font-semibold text-ink md:text-xl">&amp; Collective</p>
			</div>
		</a>

		<nav aria-label="Primary" class="hidden items-center gap-6 md:flex">
			{navigation.map((item) => (
				item.children ? (
					<div class="group" data-desktop-nav-group>
						<a class="inline-flex items-center gap-1 text-sm font-semibold text-muted transition hover:text-ink" href={item.href}>
							{item.label}
							<svg class="h-3 w-3 opacity-60 transition group-hover:rotate-180" viewBox="0 0 12 12" fill="none" aria-hidden="true">
								<path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
							</svg>
						</a>
						<div class="invisible pointer-events-none absolute left-0 right-0 top-full z-50 max-h-[25vh] overflow-y-auto opacity-0 transition-all duration-300 group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100">
							<div class="border-b border-(--color-line-soft) bg-surface py-5 shadow-(--shadow-medium)">
								<div class="mx-auto max-w-6xl px-6 lg:px-10">
									{item.children.map((child) => (
										<a class="block py-2.5 text-sm font-semibold text-muted transition hover:text-ink" href={child.href}>
											{child.label}
										</a>
									))}
								</div>
							</div>
						</div>
					</div>
				) : (
					<a class="text-sm font-semibold text-muted transition hover:text-ink" href={item.href}>
						{item.label}
					</a>
				)
			))}
		</nav>

		<div class="hidden items-center gap-2.5 md:flex">
			<button
				type="button"
				class="theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full bg-surface p-0 text-muted shadow-sm transition hover:-translate-y-0.5 hover:text-ink hover:shadow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				data-theme-toggle
				aria-label="Switch to dark mode"
				aria-pressed="false"
			>
				<svg class="theme-toggle__icon h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path class="theme-toggle__bulb" d="M9 18h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M10 21h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M8.5 14.5c-.9-.98-1.5-2.33-1.5-3.84A5 5 0 0 1 12 5.66a5 5 0 0 1 5 5c0 1.51-.6 2.86-1.5 3.84-.69.75-1.5 1.66-1.5 2.84h-4c0-1.18-.81-2.09-1.5-2.84Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
					<path class="theme-toggle__filament" d="M10.45 11.1a1.55 1.55 0 1 1 3.1 0c0 .68-.31 1.08-.64 1.42-.36.37-.76.77-.9 1.42h-1.02c-.14-.65-.54-1.05-.9-1.42-.33-.34-.64-.74-.64-1.42Z" />
					<g class="theme-toggle__rays">
						<path d="M12 2.75v1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m5.81 5.81 1.06 1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M3 12h1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m17.13 6.87 1.06-1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M19.5 12H21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					</g>
				</svg>
				<span class="sr-only" data-theme-label>Dark mode</span>
			</button>
			<a
				class="inline-flex items-center rounded-full bg-accent px-5 py-2.5 text-sm font-semibold text-(--color-button-ink) shadow-(--shadow-brand) transition hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				href="/#contact"
			>
				Inquire Now
			</a>
		</div>
	</div>

	<div class="flex items-center justify-between px-4 py-3 md:hidden">
		<a
			class="inline-flex items-center rounded-full bg-accent px-4 py-2 text-sm font-semibold text-(--color-button-ink) shadow-(--shadow-brand) transition hover:-translate-y-0.5"
			href="/#contact"
		>
			Inquire Now
		</a>
		<div class="flex items-center gap-2">
			<button
				type="button"
				class="theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full bg-surface p-0 text-muted shadow-sm transition hover:text-ink hover:shadow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				data-theme-toggle
				aria-label="Switch to dark mode"
				aria-pressed="false"
			>
				<svg class="theme-toggle__icon h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path class="theme-toggle__bulb" d="M9 18h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M10 21h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M8.5 14.5c-.9-.98-1.5-2.33-1.5-3.84A5 5 0 0 1 12 5.66a5 5 0 0 1 5 5c0 1.51-.6 2.86-1.5 3.84-.69.75-1.5 1.66-1.5 2.84h-4c0-1.18-.81-2.09-1.5-2.84Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
					<path class="theme-toggle__filament" d="M10.45 11.1a1.55 1.55 0 1 1 3.1 0c0 .68-.31 1.08-.64 1.42-.36.37-.76.77-.9 1.42h-1.02c-.14-.65-.54-1.05-.9-1.42-.33-.34-.64-.74-.64-1.42Z" />
					<g class="theme-toggle__rays">
						<path d="M12 2.75v1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m5.81 5.81 1.06 1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M3 12h1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m17.13 6.87 1.06-1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M19.5 12H21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					</g>
				</svg>
				<span class="sr-only" data-theme-label>Dark mode</span>
			</button>
			<button
				id="mobile-menu-toggle"
				type="button"
				class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-surface text-muted shadow-sm transition hover:text-ink hover:shadow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				aria-label="Open menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg id="icon-hamburger" class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
				</svg>
				<svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
				</svg>
			</button>
		</div>
	</div>

	<div
		id="mobile-menu"
		class="hidden md:hidden overflow-y-auto"
		style="background: linear-gradient(to bottom, color-mix(in srgb, var(--color-surface) 78%, transparent), var(--color-header-bg)); max-height: calc(100vh - 60px); max-height: calc(100dvh - 60px);"
		aria-hidden="true"
	>
		<div class="space-y-2 px-5 pt-4 pb-4">
			{mobileVisibleNav.map((item) => (
				item.children ? (
					<div class="rounded-2xl border border-(--color-line-soft) bg-surface p-3 shadow-(--shadow-soft)">
						<a class="block px-1 py-1 text-sm font-semibold text-ink" href={item.href}>{item.label}</a>
						<div class="mt-2 space-y-1">
							{item.children.map((child) => (
								<a class="block rounded-xl px-3 py-2 text-sm font-semibold text-muted transition hover:bg-(--color-surface-strong) hover:text-ink" href={child.href}>
									{child.label}
								</a>
							))}
						</div>
					</div>
				) : (
					<a class="block rounded-2xl border border-(--color-line-soft) bg-surface px-4 py-3 text-sm font-semibold text-ink shadow-(--shadow-soft)" href={item.href}>
						{item.label}
					</a>
				)
			))}

			{/* "More" collapsible section */}
			<div class="rounded-2xl border border-(--color-line-soft) bg-surface shadow-(--shadow-soft)">
				<button
					id="mobile-more-toggle"
					type="button"
					class="flex w-full items-center justify-between px-4 py-3 text-sm font-semibold text-ink"
					aria-expanded="false"
					aria-controls="mobile-more-items"
				>
					More
					<svg id="more-chevron" class="h-4 w-4 text-muted transition-transform" viewBox="0 0 12 12" fill="none" aria-hidden="true">
						<path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
					</svg>
				</button>
				<div id="mobile-more-items" class="hidden px-3 pb-3 space-y-1">
					{mobileMoreNav.map((item) => (
						item.children ? (
							<div>
								<a class="block px-1 py-1 text-sm font-semibold text-ink" href={item.href}>{item.label}</a>
								<div class="mt-1 space-y-1">
									{item.children.map((child) => (
										<a class="block rounded-xl px-3 py-2 text-sm font-semibold text-muted transition hover:bg-(--color-surface-strong) hover:text-ink" href={child.href}>
											{child.label}
										</a>
									))}
								</div>
							</div>
						) : (
							<a class="block rounded-xl px-3 py-2 text-sm font-semibold text-muted transition hover:bg-(--color-surface-strong) hover:text-ink" href={item.href}>
								{item.label}
							</a>
						)
					))}
				</div>
			</div>
		</div>
	</div>

</header>

<div id="nav-backdrop" class="pointer-events-none fixed inset-0 z-30 hidden backdrop-blur-sm transition-opacity duration-300" style="background: rgba(0,0,0,0.06);" aria-hidden="true"></div>

<script>
	const menuToggle = document.getElementById('mobile-menu-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	const iconHamburger = document.getElementById('icon-hamburger');
	const iconClose = document.getElementById('icon-close');

	if (menuToggle && mobileMenu) {
		menuToggle.addEventListener('click', () => {
			const isClosed = mobileMenu.classList.toggle('hidden');
			mobileMenu.setAttribute('aria-hidden', String(isClosed));
			menuToggle.setAttribute('aria-expanded', String(!isClosed));
			iconHamburger?.classList.toggle('hidden', !isClosed);
			iconClose?.classList.toggle('hidden', isClosed);
			// Prevent body scroll when menu is open
			document.body.style.overflow = isClosed ? '' : 'hidden';
		});
	}

	// Desktop nav backdrop blur
	const desktopNavGroups = document.querySelectorAll('[data-desktop-nav-group]');
	const navBackdrop = document.getElementById('nav-backdrop');

	desktopNavGroups.forEach(group => {
		group.addEventListener('mouseenter', () => {
			navBackdrop?.classList.remove('hidden');
		});
		group.addEventListener('mouseleave', () => {
			navBackdrop?.classList.add('hidden');
		});
	});

	// "More" toggle in mobile menu
	const moreToggle = document.getElementById('mobile-more-toggle');
	const moreItems = document.getElementById('mobile-more-items');
	const moreChevron = document.getElementById('more-chevron');

	if (moreToggle && moreItems) {
		moreToggle.addEventListener('click', () => {
			const isHidden = moreItems.classList.toggle('hidden');
			moreToggle.setAttribute('aria-expanded', String(!isHidden));
			moreChevron?.classList.toggle('rotate-180', !isHidden);
		});
	}
</script>
