---
import { Image } from 'astro:assets';
import logoPlaceholder from '../assets/logo-placeholder.svg';

const contact = {
	phoneLabel: 'Call: +1 (000) 000-0000',
	shortLabel: 'Call',
	phoneHref: 'tel:+10000000000',
};

type SubheaderItem = { label: string; href: string };
type GroupItem = { label: string; href: string };
type Group = { heading: string; href?: string; items: GroupItem[] };
type FlatNavItem = { label: string; href: string; subheaders: SubheaderItem[]; groups?: never };
type GroupedNavItem = { label: string; href: string; groups: Group[]; subheaders?: never };
type NavItem = FlatNavItem | GroupedNavItem;

const navigation: NavItem[] = [
	{
		label: 'About',
		href: '#about',
		subheaders: [
			{ label: 'Our Story', href: '#about-story' },
			{ label: 'Team', href: '#about-team' },
		],
	},
	{
		label: 'Services',
		href: '/services',
		groups: [
			{
				heading: 'Psychological Evaluations',
				href: '/services/psychological-evaluations',
				items: [
					{ label: 'ADHD Testing', href: '/services/psychological-evaluations/adhd' },
					{ label: 'Autism Testing', href: '/services/psychological-evaluations/autism' },
					{ label: 'Personality Disorders', href: '/services/psychological-evaluations/personality-disorders' },
				],
			},
			{
				heading: 'Psychoeducational Testing',
				href: '/services/psychoeducational-testing',
				items: [
					{ label: 'Dyslexia Testing', href: '/services/psychoeducational-testing/dyslexia' },
					{ label: 'Learning Disorders', href: '/services/psychoeducational-testing/learning-disorders' },
					{ label: 'Giftedness', href: '/services/psychoeducational-testing/giftedness' },
					{ label: 'Academic Achievement', href: '/services/psychoeducational-testing/academic-achievement' },
					{ label: '2E Testing', href: '/services/psychoeducational-testing/2e-testing' },
				],
			},
		],
	},
	{
		label: 'CEU Trainings',
		href: '/services/ceu-trainings',
		groups: [
			{
				heading: 'CEU Trainings',
				href: '/services/ceu-trainings',
				items: [
					{ label: 'All CEU Trainings', href: '/services/ceu-trainings' },
					{ label: 'ADHD Training', href: '/services/ceu-trainings/adhd-training' },
					{ label: 'Autism Testing Training', href: '/services/ceu-trainings/autism-testing-training' },
				],
			},
		],
	},
	{
		label: 'Consultation',
		href: '/services/billing-and-credentialing-consultation',
		subheaders: [
			{ label: 'Consultation Overview', href: '/services/billing-and-credentialing-consultation' },
			{ label: 'Billing & Credentialing', href: '/services/billing-and-credentialing-consultation' },
			{ label: 'Book a Call', href: '/services/billing-and-credentialing-consultation#book-a-call' },
			{ label: 'Frequently Asked Questions', href: '/services/billing-and-credentialing-consultation#faq' },
		],
	},
];
---

<header class="sticky top-0 z-40 border-b border-(--color-line) bg-(--color-header-bg) backdrop-blur">
	<div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:gap-6 sm:px-6 sm:py-4 lg:px-10">
		<a class="shrink-0" href="/" aria-label="Morning Tide home">
			<Image src={logoPlaceholder} alt="Morning Tide logo" width={180} height={60} class="site-logo h-auto w-28 sm:w-37.5 lg:w-45" />
		</a>

		<nav aria-label="Primary" class="hidden items-center gap-2 md:flex">
			{navigation.map((item) => (
				<div class="group relative">
					<a class="rounded-full px-4 py-2 text-sm font-semibold text-(--color-muted) transition hover:bg-(--color-surface) hover:text-(--color-ink)" href={item.href}>
						{item.label}
					</a>
					{item.groups ? (
						<div class="pointer-events-none invisible absolute left-0 top-full z-20 min-w-120 pt-2 opacity-0 transition duration-150 group-hover:visible group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100 group-focus-within:pointer-events-auto">
							<div class="rounded-2xl border border-(--color-line) bg-(--color-surface) p-4 shadow-(--shadow-medium)">
								<div class="grid grid-cols-3 gap-x-4 gap-y-2">
									{item.groups.map((group) => (
										<div>
											{group.href ? (
												<a class="mb-2 block text-[11px] font-semibold uppercase tracking-[0.18em] text-(--color-brand) hover:underline" href={group.href}>
													{group.heading}
												</a>
											) : (
												<p class="mb-2 text-[11px] font-semibold uppercase tracking-[0.18em] text-(--color-muted)">{group.heading}</p>
											)}
											<ul class="space-y-1">
												{group.items.map((link) => (
													<li>
														<a class="block rounded-lg px-2 py-1 text-sm text-(--color-muted) transition hover:bg-(--color-page) hover:text-(--color-ink)" href={link.href}>
															{link.label}
														</a>
													</li>
												))}
											</ul>
										</div>
									))}
								</div>
							</div>
						</div>
					) : (
						<div class="pointer-events-none invisible absolute left-0 top-full z-20 min-w-52 pt-2 opacity-0 transition duration-150 group-hover:visible group-hover:opacity-100 group-hover:pointer-events-auto group-focus-within:visible group-focus-within:opacity-100 group-focus-within:pointer-events-auto">
							<div class="rounded-2xl border border-(--color-line) bg-(--color-surface) p-3 shadow-(--shadow-medium)">
								<ul class="space-y-2">
									{item.subheaders.map((subheader) => (
										<li>
											<a class="block rounded-lg px-2 py-1 text-sm text-(--color-muted) transition hover:bg-(--color-page) hover:text-(--color-ink)" href={subheader.href}>
												{subheader.label}
											</a>
										</li>
									))}
								</ul>
							</div>
						</div>
					)}
				</div>
			))}
		</nav>

		<div class="flex shrink-0 items-center gap-2 sm:gap-3">
			<button
				type="button"
				class="theme-toggle inline-flex h-10 w-10 items-center justify-center rounded-full border border-(--color-line) bg-(--color-surface) p-0 text-(--color-ink) transition hover:-translate-y-0.5 hover:bg-(--color-surface-strong) focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				data-theme-toggle
				aria-label="Switch to dark mode"
				aria-pressed="false"
			>
				<svg class="theme-toggle__icon h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path class="theme-toggle__bulb" d="M9 18h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M10 21h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M8.5 14.5c-.9-.98-1.5-2.33-1.5-3.84A5 5 0 0 1 12 5.66a5 5 0 0 1 5 5c0 1.51-.6 2.86-1.5 3.84-.69.75-1.5 1.66-1.5 2.84h-4c0-1.18-.81-2.09-1.5-2.84Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
					<path class="theme-toggle__filament" d="M10.45 11.1a1.55 1.55 0 1 1 3.1 0c0 .68-.31 1.08-.64 1.42-.36.37-.76.77-.9 1.42h-1.02c-.14-.65-.54-1.05-.9-1.42-.33-.34-.64-.74-.64-1.42Z" />
					<g class="theme-toggle__rays">
						<path d="M12 2.75v1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m5.81 5.81 1.06 1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M3 12h1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m17.13 6.87 1.06-1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M19.5 12H21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					</g>
				</svg>
				<span class="sr-only" data-theme-label>Dark mode</span>
			</button>

			<a class="inline-flex items-center rounded-full border border-(--color-line) bg-(--color-surface) px-3 py-2 text-sm font-semibold text-(--color-ink) transition hover:-translate-y-0.5 sm:px-4" href={contact.phoneHref}>
				<span class="sm:hidden">{contact.shortLabel}</span>
				<span class="hidden sm:inline">{contact.phoneLabel}</span>
			</a>
		</div>
	</div>
</header>
