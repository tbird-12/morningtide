---
const navigation = [
	{ label: 'Home', href: '/' },
	{ label: 'Psychological Evaluations', href: '/services/psychological-evaluations' },
	{ label: 'Psychoeducational Evaluations', href: '/services/psychoeducational-testing' },
	{ label: 'Clinician Consultations', href: '/services/billing-and-credentialing-consultation' },
	{ label: 'CEU Trainings', href: '/services/ceu-trainings' },
	{ label: 'Contact', href: '/#contact' },
];
---

<header class="sticky top-0 z-40 border-b border-(--color-line-soft) bg-(--color-header-bg) backdrop-blur-xl">
	<div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 md:px-6 lg:px-10">
		<a class="group flex items-center gap-4" href="/" aria-label="Morning Tide Consulting and Collective home">
			<div class="flex h-11 w-11 items-center justify-center rounded-full border border-(--color-line) bg-(--color-surface) text-lg font-semibold text-(--color-brand) shadow-(--shadow-soft)">
				MCC
			</div>
			<div>
				<p class="text-[0.68rem] font-semibold uppercase tracking-[0.32em] text-(--color-brand)">Morning Tide Consulting</p>
				<p class="text-lg font-semibold text-(--color-ink) md:text-xl">&amp; Collective</p>
			</div>
		</a>

		<nav aria-label="Primary" class="hidden items-center gap-7 md:flex">
			{navigation.map((item) => (
				<a class="text-sm font-semibold text-(--color-muted) transition hover:text-(--color-ink)" href={item.href}>
					{item.label}
				</a>
			))}
		</nav>

		<div class="hidden items-center gap-2.5 md:flex">
			<button
				type="button"
				class="theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full bg-(--color-surface) p-0 text-(--color-muted) shadow-sm transition hover:-translate-y-0.5 hover:text-(--color-ink) hover:shadow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				data-theme-toggle
				aria-label="Switch to dark mode"
				aria-pressed="false"
			>
				<svg class="theme-toggle__icon h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path class="theme-toggle__bulb" d="M9 18h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M10 21h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M8.5 14.5c-.9-.98-1.5-2.33-1.5-3.84A5 5 0 0 1 12 5.66a5 5 0 0 1 5 5c0 1.51-.6 2.86-1.5 3.84-.69.75-1.5 1.66-1.5 2.84h-4c0-1.18-.81-2.09-1.5-2.84Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
					<path class="theme-toggle__filament" d="M10.45 11.1a1.55 1.55 0 1 1 3.1 0c0 .68-.31 1.08-.64 1.42-.36.37-.76.77-.9 1.42h-1.02c-.14-.65-.54-1.05-.9-1.42-.33-.34-.64-.74-.64-1.42Z" />
					<g class="theme-toggle__rays">
						<path d="M12 2.75v1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m5.81 5.81 1.06 1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M3 12h1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m17.13 6.87 1.06-1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M19.5 12H21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					</g>
				</svg>
				<span class="sr-only" data-theme-label>Dark mode</span>
			</button>
			<a
				class="inline-flex items-center rounded-full bg-(--color-accent) px-5 py-2.5 text-sm font-semibold text-white shadow-(--shadow-brand) transition hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				href="/#contact"
			>
				Inquire Now
			</a>
		</div>
	</div>

	<div class="flex items-center justify-between border-t border-(--color-line-soft) px-4 py-3 md:hidden">
		<p class="text-xs font-semibold uppercase tracking-[0.3em] text-(--color-brand)">MCC</p>
		<div class="flex items-center gap-2">
			<button
				id="mobile-menu-toggle"
				type="button"
				class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-(--color-surface) text-(--color-muted) shadow-sm transition hover:text-(--color-ink) hover:shadow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				aria-label="Open menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<svg id="icon-hamburger" class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
				</svg>
				<svg id="icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
				</svg>
			</button>
		</div>
	</div>

	<div
		id="mobile-menu"
		class="hidden md:hidden"
		style="background: linear-gradient(to bottom, color-mix(in srgb, var(--color-surface) 78%, transparent), var(--color-header-bg));"
		aria-hidden="true"
	>
		<div class="space-y-2 px-5 pt-5 pb-5">
			{navigation.map((item) => (
				<a class="block rounded-2xl border border-(--color-line-soft) bg-(--color-surface) px-4 py-3 text-sm font-semibold text-(--color-ink) shadow-(--shadow-soft)" href={item.href}>
						{item.label}
					</a>
			))}
			<a class="inline-flex w-full items-center justify-center rounded-full bg-(--color-accent) px-5 py-3 text-sm font-semibold text-white shadow-(--shadow-brand)" href="/#contact">
				Inquire Now
			</a>
		</div>
		<div class="flex items-center justify-between px-6 py-3" style="background: color-mix(in srgb, var(--color-surface) 30%, transparent);">
			<span class="text-sm font-semibold text-(--color-muted)">Appearance</span>
			<button
				type="button"
				class="theme-toggle inline-flex h-9 w-9 items-center justify-center rounded-full bg-(--color-surface) p-0 text-(--color-muted) shadow-sm transition hover:text-(--color-ink) hover:shadow focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-(--color-brand)"
				data-theme-toggle
				aria-label="Switch to dark mode"
				aria-pressed="false"
			>
				<svg class="theme-toggle__icon h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
					<path class="theme-toggle__bulb" d="M9 18h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M10 21h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					<path class="theme-toggle__bulb" d="M8.5 14.5c-.9-.98-1.5-2.33-1.5-3.84A5 5 0 0 1 12 5.66a5 5 0 0 1 5 5c0 1.51-.6 2.86-1.5 3.84-.69.75-1.5 1.66-1.5 2.84h-4c0-1.18-.81-2.09-1.5-2.84Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
					<path class="theme-toggle__filament" d="M10.45 11.1a1.55 1.55 0 1 1 3.1 0c0 .68-.31 1.08-.64 1.42-.36.37-.76.77-.9 1.42h-1.02c-.14-.65-.54-1.05-.9-1.42-.33-.34-.64-.74-.64-1.42Z" />
					<g class="theme-toggle__rays">
						<path d="M12 2.75v1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m5.81 5.81 1.06 1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M3 12h1.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="m17.13 6.87 1.06-1.06" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
						<path d="M19.5 12H21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
					</g>
				</svg>
				<span class="sr-only" data-theme-label>Dark mode</span>
			</button>
		</div>
	</div>

</header>

<script>
	const menuToggle = document.getElementById('mobile-menu-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	const iconHamburger = document.getElementById('icon-hamburger');
	const iconClose = document.getElementById('icon-close');

	if (menuToggle && mobileMenu) {
		menuToggle.addEventListener('click', () => {
			const isClosed = mobileMenu.classList.toggle('hidden');
			mobileMenu.setAttribute('aria-hidden', String(isClosed));
			menuToggle.setAttribute('aria-expanded', String(!isClosed));
			iconHamburger?.classList.toggle('hidden', !isClosed);
			iconClose?.classList.toggle('hidden', isClosed);
		});
	}
</script>
