---
const footer = {
	brand: 'Morning Tide Consulting and Collective',
	tagline: 'Evaluations, consultations, and education for clients and clinicians who value depth and clear communication.',
	copyright: `© ${new Date().getFullYear()} Morning Tide Consulting and Collective. All rights reserved.`,
	links: [
		{ label: 'Evaluations', href: '/services' },
		{ label: 'Consultations', href: '/services/billing-and-credentialing-consultation' },
		{ label: 'Education', href: '/services/ceu-trainings' },
		{ label: 'Investment', href: '/services/investment' },
		{ label: 'Locations', href: '/locations' },
		{ label: 'About Clinician', href: '/about-clinician' },
		{ label: 'Services Overview', href: '/services' },
		{ label: 'Inquire', href: '/#contact' },
	],
};
---


<footer class="border-t border-(--color-line-soft) bg-(--color-surface)">
	<div class="mx-auto grid w-full max-w-6xl gap-10 px-6 py-12 lg:grid-cols-[1.2fr_0.8fr] lg:px-10">
		<div class="space-y-4">
			<p class="text-[0.72rem] font-semibold uppercase tracking-[0.34em] text-(--color-brand)">Morning Tide Consulting and Collective</p>
			<h2 class="text-3xl leading-none text-(--color-ink) sm:text-4xl">Evaluation, consultation, and education — all under one practice.</h2>
			<p class="max-w-2xl text-base leading-7 text-(--color-muted)">{footer.tagline}</p>
			<p class="text-sm text-(--color-muted)">{footer.copyright}</p>
		</div>
		<nav aria-label="Footer" class="grid gap-3 text-sm">
			{footer.links.map((link) => (
				<a class="font-semibold text-(--color-muted) transition hover:text-(--color-ink)" href={link.href}>{link.label}</a>
			))}
		</nav>
	</div>
</footer>
