---
const footer = {
	brand: 'Morning Tide',
	copyright: `© ${new Date().getFullYear()} Morning Tide. All rights reserved.`,
	links: [
		{ label: 'About', href: '#about' },
		{ label: 'Services', href: '#services' },
		{ label: 'Consultation', href: '#consultation' },
	],
};
---

<footer class="border-t border-(--color-line) bg-(--color-surface)">
	<div class="mx-auto flex w-full max-w-6xl flex-col gap-4 px-6 py-8 text-sm text-(--color-muted) lg:flex-row lg:items-center lg:justify-between lg:px-10">
		<div class="flex flex-col gap-1">
			<p class="font-semibold uppercase tracking-[0.2em] text-(--color-ink)">{footer.brand}</p>
			<p>{footer.copyright}</p>
		</div>
		<nav aria-label="Footer" class="flex flex-wrap items-center gap-4">
			{footer.links.map((link) => (
				<a class="font-medium text-(--color-muted) transition hover:text-(--color-ink)" href={link.href}>{link.label}</a>
			))}
		</nav>
	</div>
</footer>
