// ACCESS CONTROL
// ============================================================================

/**
 * Check if user is authorized to edit this cell
 * (Currently informational; Google Sheets doesn't support blocking at script level)
 * 
 * Returns true if:
 * - User is the task owner (Current Owner matches user)
 * - User is an admin (has full access)
 */
function checkEditAuthorization(sheet, row, userEmail) {
  const currentOwner = sheet.getRange(row, CONFIG.COLUMNS.CURRENT_OWNER).getValue();
  
  // Extract first name from email
  const userFirstName = userEmail.split('@')[0].charAt(0).toUpperCase() + 
                       userEmail.split('@')[0].slice(1);
  
  // Check if user is an admin (has full access)
  if (CONFIG.ADMIN_USERS.includes(userFirstName)) {
    return true;
  }
  
  // Check if user owns this task
  if (userFirstName === currentOwner) {
    return true;
  }
  
  // User is not authorized
  const ui = SpreadsheetApp.getUi();
  ui.alert('You can only edit tasks assigned to you. Contact an administrator for access.');
  return false;
}

