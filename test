// ============================================================================
// MAIN EVENT HANDLERS
// ============================================================================

/**
 * Runs when sheet is opened
 */
function onOpen(e) {
  sortMasterByPriority();
  addMenuItems();
}

/**
 * Runs when any cell is edited
 */
function onEdit(e) {
  const sheet = e.source.getActiveSheet();
  const range = e.range;
  const row = range.getRow();
  const col = range.getColumn();
  const value = range.getValue();
  
  if (row === 1) return; // Skip header row
  
  // Handle outreach attempt changes
  if (col === CONFIG.COLUMNS.OUTREACH_ATTEMPTS) {
    handleOutreachAttempt(sheet, row, value);
  }
  
  // Handle document completion
  if (col === CONFIG.COLUMNS.DOCUMENTS_COMPLETE && value === true) {
    handleDocumentsComplete(sheet, row);
  }
  
  // Handle status changes (for auto-owner updates and denial confirmation)
  if (col === CONFIG.COLUMNS.STATUS) {
    // Check if status is Denied - require denial reason if so
    if (value.includes('Denied')) {
      requireDenialReason(sheet, row, value);
    }
    handleStatusChange(sheet, row, value);
  }
  
  // Auto-update "Date Last Updated"
  updateLastUpdatedDate(sheet, row);
  
  // Re-sort Master Sheet if needed
  if (sheet.getName() === CONFIG.SHEETS.MASTER) {
    sortMasterByPriority();
  }
}

/**
 * Add custom menu to Google Sheet
 */
function addMenuItems() {
  const ui = SpreadsheetApp.getUi();
  ui.createMenu('Clinical Management')
    .addItem('Sort by Priority (Self-Pay First)', 'sortMasterByPriority')
    .addItem('Archive Completed Tasks', 'archiveCompletedTasks')
    .addItem('Un-Archive Client', 'showReactivationDialog')
    .addSeparator()
    .addItem('Refresh All Sheets', 'refreshAllSheets')
    .addToUi();
}

// ============================================================================
// OUTREACH TRACKING
// ============================================================================

/**
 * Handle outreach attempt selection
 */
function handleOutreachAttempt(sheet, row, attemptValue) {
  const range = sheet.getRange(row, CONFIG.COLUMNS.LAST_OUTREACH_DATE);
  const nextOutreachRange = sheet.getRange(row, CONFIG.COLUMNS.NEXT_OUTREACH_DUE);
  
  if (attemptValue === 'None') {
    range.clearContent();
    nextOutreachRange.clearContent();
    return;
  }
  
  if (attemptValue.includes('Attempt')) {
    // Auto-populate Last Outreach Date
    range.setValue(new Date());
    
    // Calculate Next Outreach Due (3 business days)
    const nextDate = addBusinessDays(new Date(), CONFIG.OUTREACH_DAYS_UNTIL_NEXT);
    nextOutreachRange.setValue(nextDate);
    
    // Check if this is Attempt 3 - if so, archive
    if (attemptValue === 'Attempt 3') {
      checkAndArchiveNoResponse(sheet, row);
    }
  }
}

/**
 * Check if Attempt 3 is within 10 business days and archive if so
 */
function checkAndArchiveNoResponse(sheet, row) {
  const firstAttemptCell = sheet.getRange(row, CONFIG.COLUMNS.LAST_OUTREACH_DATE).getValue();
  
  if (!firstAttemptCell) return; // No date yet
  
  const today = new Date();
  const businessDaysDiff = getBusinessDaysBetween(firstAttemptCell, today);
  
  if (businessDaysDiff <= CONFIG.OUTREACH_BUSINESS_DAYS) {
    // Auto-archive this row
    sheet.getRange(row, CONFIG.COLUMNS.ARCHIVE_REASON).setValue('No Response - 3x Outreach');
    sheet.getRange(row, CONFIG.COLUMNS.STATUS).setValue('No Response - Archived');
    sheet.getRange(row, CONFIG.COLUMNS.DATE_ARCHIVED).setValue(new Date());
    
    // Move to Archive sheet (happens via next sync)
    moveRowToArchive(sheet, row);
  }
}

/**
 * Move row to Archive sheet
 */
function moveRowToArchive(sourceSheet, row) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const archiveSheet = ss.getSheetByName(CONFIG.SHEETS.ARCHIVE);
  
  if (!archiveSheet) return; // Archive sheet doesn't exist
  
  const sourceValues = sourceSheet.getRange(row, 1, 1, 18).getValues();
  archiveSheet.appendRow(sourceValues[0]);
  
  // Clear source row (but keep headers)
  sourceSheet.deleteRow(row);
}

// ============================================================================
// DOCUMENT COMPLETION
// ============================================================================

/**
 * When Documents Complete changes to true, create rows on clinician sheets
 */
function handleDocumentsComplete(sheet, row) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  
  // Get client info
  const clientFirstName = sheet.getRange(row, CONFIG.COLUMNS.FIRST_NAME).getValue();
  const clientLastInitial = sheet.getRange(row, CONFIG.COLUMNS.LAST_NAME_INITIAL).getValue();
  const servicesRequested = sheet.getRange(row, CONFIG.COLUMNS.SERVICES_REQUESTED).getValue();
  const insuranceType = sheet.getRange(row, CONFIG.COLUMNS.INSURANCE_TYPE).getValue();
  
  // Update status on Master Sheet
  sheet.getRange(row, CONFIG.COLUMNS.STATUS).setValue('Documents Complete - Ready for Clinician Review');
  
  // Parse services (comma-separated)
  const services = servicesRequested.split(',').map(s => s.trim());
  
  // Create rows on clinician sheets for each service
  services.forEach(service => {
    const clinicianName = getClinicianForService(service);
    const clinicianSheet = ss.getSheetByName(getSheetNameForClinician(clinicianName));
    
    if (clinicianSheet) {
      const newRow = [
        clientFirstName,
        clientLastInitial,
        insuranceType,
        servicesRequested,
        service,
        clinicianName,
        'New - Awaiting Clinician Review',
        '', // Documents Complete (not used on clinician sheet)
        'None', // Outreach Attempts
        '', // Last Outreach Date
        '', // Next Outreach Due
        'Documents complete. Ready for review.',
        new Date(), // Date Created
        new Date(), // Date Last Updated
        'None', // Archive Reason
        'No', // Previously Archived
        '', // Date Archived
        ''  // Date Reactivated
      ];
      clinicianSheet.appendRow(newRow);
    }
  });
}

/**
 * Get clinician name for given service
 */
function getClinicianForService(service) {
  service = service.trim().toLowerCase();
  
  // Search through CLINICIANS array for matching service
  for (let i = 0; i < CONFIG.CLINICIANS.length; i++) {
    const clinician = CONFIG.CLINICIANS[i];
    if (clinician.service.toLowerCase().includes(service) || 
        service.includes(clinician.service.toLowerCase())) {
      return clinician.name;
    }
  }
  
  // Fallback to first admin if no matching clinician
  return CONFIG.ADMIN_USERS[0] || 'Samantha';
}

/**
 * Get sheet name for clinician
 */
function getSheetNameForClinician(clinicianName) {
  // Search through CLINICIANS array for sheet name
  for (let i = 0; i < CONFIG.CLINICIANS.length; i++) {
    if (CONFIG.CLINICIANS[i].name === clinicianName) {
      return CONFIG.CLINICIANS[i].sheet;
    }
  }
  
  // If it's an admin user, return their queue sheet
  if (CONFIG.ADMIN_USERS.includes(clinicianName)) {
    return clinicianName + "'s Queue";
  }
  
  return CONFIG.SHEETS.MASTER; // Default fallback
}

// ============================================================================
// STATUS CHANGES & AUDIT TRAIL
// ============================================================================

/**
 * Require denial reason before allowing Denied status
 */
function requireDenialReason(sheet, row, status) {
  const notes = sheet.getRange(row, CONFIG.COLUMNS.NOTES).getValue();
  
  // If notes are empty, prompt user for denial reason
  if (!notes || notes.trim() === '') {
    const ui = SpreadsheetApp.getUi();
    const response = ui.prompt(
      'Denial Reason Required',
      'Please enter the reason for denial before proceeding:',
      ui.ButtonSet.OK_CANCEL
    );
    
    if (response.getSelectedButton() === ui.Button.OK) {
      const denialReason = response.getResponseText();
      if (denialReason && denialReason.trim() !== '') {
        // Add denial reason to Notes
        sheet.getRange(row, CONFIG.COLUMNS.NOTES).setValue(denialReason);
        // Append to audit trail with timestamp
        appendToAuditTrail(sheet, row, status, denialReason);
      } else {
        // If user didn't provide reason, revert status change
        ui.alert('Denial reason is required. Status change cancelled.');
        sheet.getRange(row, CONFIG.COLUMNS.STATUS).clearContent();
      }
    } else {
      // User cancelled - revert status
      sheet.getRange(row, CONFIG.COLUMNS.STATUS).clearContent();
    }
  } else {
    // Notes already exist - append status transition to audit trail
    appendToAuditTrail(sheet, row, status, notes);
  }
}

/**
 * Append status transition and notes to audit trail
 */
function appendToAuditTrail(sheet, row, newStatus, notes) {
  const auditTrailCell = sheet.getRange(row, CONFIG.COLUMNS.AUDIT_TRAIL);
  const currentAuditTrail = auditTrailCell.getValue();
  
  const timestamp = new Date().toLocaleString();
  const currentOwner = sheet.getRange(row, CONFIG.COLUMNS.CURRENT_OWNER).getValue();
  const newEntry = `[${timestamp}] ${currentOwner} → ${newStatus}: ${notes}`;
  
  // Append to existing audit trail
  const updatedTrail = currentAuditTrail ? currentAuditTrail + '\n---\n' + newEntry : newEntry;
  auditTrailCell.setValue(updatedTrail);
}

// ============================================================================
// STATUS CHANGES
// ============================================================================

/**
 * Handle status changes (e.g., when approved/denied, update owner)
 */
function handleStatusChange(sheet, row, status) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const primaryAdmin = CONFIG.ADMIN_USERS[0] || 'Samantha';
  
  // If status is Approved, move to primary admin
  if (status.includes('Approved')) {
    sheet.getRange(row, CONFIG.COLUMNS.CURRENT_OWNER).setValue(primaryAdmin);
  }
  
  // If status is Denied, move to primary admin
  if (status.includes('Denied')) {
    sheet.getRange(row, CONFIG.COLUMNS.CURRENT_OWNER).setValue(primaryAdmin);
  }
  
  // If status is "Recommend to X", parse and update owner
  if (status.includes('Recommend to')) {
    const recommendedClinicianMatch = status.match(/Recommend to ([A-Za-z]+)/);
    if (recommendedClinicianMatch) {
      const recommendedClinician = recommendedClinicianMatch[1];
      sheet.getRange(row, CONFIG.COLUMNS.CURRENT_OWNER).setValue(recommendedClinician);
      
      // Create duplicate row on recommended clinician's sheet
      createDuplicateForRecommendation(sheet, row, recommendedClinician);
    }
  }
}

/**
 * Create a duplicate row on recommended clinician's sheet
 */
function createDuplicateForRecommendation(sourceSheet, row, recommendedClinician) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const targetSheet = ss.getSheetByName(getSheetNameForClinician(recommendedClinician));
  
  if (!targetSheet) return;
  
  const sourceValues = sourceSheet.getRange(row, 1, 1, 19).getValues();
  targetSheet.appendRow(sourceValues[0]);
}

