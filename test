/**
 * Sort Master Sheet by priority: Self-Pay first, then by Status
 */
function sortMasterByPriority() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const sheet = ss.getSheetByName(CONFIG.SHEETS.MASTER);
  
  if (!sheet) return;
  
  // Get all data (excluding header)
  const range = sheet.getDataRange();
  const values = range.getValues();
  
  if (values.length <= 1) return; // Only header or empty
  
  const header = values[0];
  const data = values.slice(1);
  
  // Sort by Insurance Type (Self-Pay first), then by Status urgency
  data.sort((a, b) => {
    const aInsurance = a[CONFIG.COLUMNS.INSURANCE_TYPE - 1] || '';
    const bInsurance = b[CONFIG.COLUMNS.INSURANCE_TYPE - 1] || '';
    
    // Self-Pay comes first
    if (aInsurance === 'Self-Pay' && bInsurance !== 'Self-Pay') return -1;
    if (aInsurance !== 'Self-Pay' && bInsurance === 'Self-Pay') return 1;
    
    // Then sort by Status urgency
    const aStatus = a[CONFIG.COLUMNS.STATUS - 1] || '';
    const bStatus = b[CONFIG.COLUMNS.STATUS - 1] || '';
    
    const statusOrder = [
      'New - Awaiting Documents',
      'New - Awaiting Clinician Review',
      'In Review',
      'Records Request',
      'Awaiting Records - With Samantha',
      'Documents Complete - Ready for Clinician Review',
      'Approved - Awaiting Scheduling',
      'Denied - Awaiting Client Notification',
      'Scheduled',
      'Denied - Client Notified'
    ];
    
    const aIndex = statusOrder.indexOf(aStatus);
    const bIndex = statusOrder.indexOf(bStatus);
    
    return (aIndex === -1 ? 999 : aIndex) - (bIndex === -1 ? 999 : bIndex);
  });
  
  // Clear and rewrite
  sheet.clearContents();
  const newValues = [header, ...data];
  sheet.getRange(1, 1, newValues.length, newValues[0].length).setValues(newValues);
}

/**
 * Refresh all sheets (re-sort, re-format)
 */
function refreshAllSheets() {
  sortMasterByPriority();
  
  const ui = SpreadsheetApp.getUi();
  ui.alert('All sheets refreshed!');
}

// ============================================================================
// ARCHIVE MANAGEMENT
// ============================================================================

/**
 * Archive all completed tasks
 */
function archiveCompletedTasks() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const masterSheet = ss.getSheetByName(CONFIG.SHEETS.MASTER);
  const archiveSheet = ss.getSheetByName(CONFIG.SHEETS.ARCHIVE);
  
  if (!masterSheet || !archiveSheet) return;
  
  const values = masterSheet.getDataRange().getValues();
  const rowsToDelete = [];
  
  for (let i = 1; i < values.length; i++) {
    const status = values[i][CONFIG.COLUMNS.STATUS - 1];
    
    if (status === 'Scheduled' || status === 'Denied - Client Notified') {
      // Copy to archive
      archiveSheet.appendRow(values[i]);
      rowsToDelete.push(i + 1); // +1 because array is 0-indexed
    }
  }
  
  // Delete rows in reverse order (to maintain indices)
  for (let i = rowsToDelete.length - 1; i >= 0; i--) {
    masterSheet.deleteRow(rowsToDelete[i]);
  }
  
  const ui = SpreadsheetApp.getUi();
  ui.alert(`Archived ${rowsToDelete.length} completed tasks.`);
}

/**
 * Show dialog to un-archive a client
 */
function showReactivationDialog() {
  const html = HtmlService.createHtmlOutput(`
    <p>Enter the client name to reactivate:</p>
    <input type="text" id="clientName" placeholder="e.g., John S">
    <button onclick="reactivateClient()">Reactivate</button>
    <script>
      function reactivateClient() {
        const name = document.getElementById('clientName').value;
        google.script.run.reactivateClientByName(name);
      }
    </script>
  `);
  
  SpreadsheetApp.getUi().showModelessDialog(html, 'Reactivate Client');
}

/**
 * Reactivate a client from archive
 */
function reactivateClientByName(clientName) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const archiveSheet = ss.getSheetByName(CONFIG.SHEETS.ARCHIVE);
  const masterSheet = ss.getSheetByName(CONFIG.SHEETS.MASTER);
  
  if (!archiveSheet || !masterSheet) return;
  
  const values = archiveSheet.getDataRange().getValues();
  let found = false;
  
  for (let i = 1; i < values.length; i++) {
    const firstName = values[i][CONFIG.COLUMNS.FIRST_NAME - 1];
    const lastInitial = values[i][CONFIG.COLUMNS.LAST_NAME_INITIAL - 1];
    const fullName = firstName + ' ' + lastInitial;
    
    if (fullName.toLowerCase().includes(clientName.toLowerCase())) {
      // Copy row back to Master Sheet
      const reactivatedRow = [...values[i]];
      reactivatedRow[CONFIG.COLUMNS.STATUS - 1] = 'New - Awaiting Documents';
      reactivatedRow[CONFIG.COLUMNS.ARCHIVE_REASON - 1] = 'None';
      reactivatedRow[CONFIG.COLUMNS.PREVIOUSLY_ARCHIVED - 1] = 'Yes';
      reactivatedRow[CONFIG.COLUMNS.DATE_REACTIVATED - 1] = new Date();
      reactivatedRow[CONFIG.COLUMNS.OUTREACH_ATTEMPTS - 1] = 'None'; // Reset for fresh tracking
      
      masterSheet.appendRow(reactivatedRow);
      archiveSheet.deleteRow(i + 1);
      
      found = true;
      break;
    }
  }
  
  const ui = SpreadsheetApp.getUi();
  if (found) {
    ui.alert('Client reactivated successfully!');
  } else {
    ui.alert('Client not found in archive.');
  }
}

