}

/**
 * Auto-populate Date Created (if empty)
 */
function updateDateCreated(sheet, row) {
  const dateCreated = sheet.getRange(row, CONFIG.COLUMNS.DATE_CREATED);
  const firstName = sheet.getRange(row, CONFIG.COLUMNS.FIRST_NAME).getValue();
  
  if (firstName && !dateCreated.getValue()) {
    dateCreated.setValue(new Date());
  }
}

